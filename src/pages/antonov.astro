---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'ORÁCULO DE LA MENTE | La Verdad Sin Filtro',
  description: 'Pregunta sin miedo. La verdad duele, pero cura.',
};
---

<Layout metadata={metadata}>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Space+Grotesk:wght@700&family=JetBrains+Mono:wght@700&display=swap');

    :root {
      --bg-dark: #050505;
      --card-bg: #0a0a0a;
      --border: rgba(255, 255, 255, 0.08);
      --accent-glow: rgba(255, 255, 255, 0.15);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background-color: var(--bg-dark);
      /* Textura de ruido sutil para dar ambiente */
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.05'/%3E%3C/svg%3E");
      min-height: 100vh;
      color: #fff;
    }

    .oraculo-wrapper {
      max-width: 1400px;
      margin: 0 auto;
      padding: 2rem 1rem;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .oraculo-container {
      background: rgba(10, 10, 10, 0.8);
      border: 1px solid var(--border);
      backdrop-filter: blur(20px);
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 0 80px rgba(0,0,0,0.8);
    }

    /* HEADER MÍSTICO */
    .header-section {
      text-align: center;
      padding: 4rem 1rem 3rem;
      border-bottom: 1px solid var(--border);
      position: relative;
      background: radial-gradient(circle at 50% -20%, rgba(255,255,255,0.08), transparent 70%);
    }

    .header-title {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(3rem, 8vw, 5rem);
      line-height: 0.85;
      text-transform: uppercase;
      letter-spacing: -0.04em;
      margin-bottom: 1rem;
      color: #fff;
      text-shadow: 0 0 30px rgba(255,255,255,0.2);
    }

    .header-subtitle {
      font-family: 'JetBrains Mono', monospace;
      color: #666;
      font-size: 0.75rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
    }

    /* GRID PRINCIPAL */
    .system-grid {
      display: grid;
      grid-template-columns: 1fr;
    }

    @media (min-width: 1024px) {
      .system-grid { grid-template-columns: 380px 1fr; }
    }

    /* PANEL DE CONTROLES */
    .oraculo-panel {
      padding: 2.5rem;
      border-right: 1px solid var(--border);
      background: rgba(0,0,0,0.4);
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .label-control {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      color: #555;
      margin-bottom: 0.8rem;
      display: block;
      letter-spacing: 0.1em;
    }

    .oraculo-input {
      width: 100%;
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--border);
      color: #fff;
      padding: 1rem;
      font-family: 'Inter', sans-serif;
      font-size: 0.95rem;
      border-radius: 4px;
      transition: 0.3s;
    }

    .oraculo-input:focus {
      border-color: #666;
      background: rgba(255,255,255,0.06);
      outline: none;
    }

    textarea.oraculo-input {
      resize: vertical;
      min-height: 140px;
      line-height: 1.6;
    }

    /* BOTONES CON CARÁCTER */
    .btn-group { display: flex; flex-direction: column; gap: 0.8rem; }

    .oraculo-btn {
      width: 100%;
      padding: 1.2rem;
      border: none;
      cursor: pointer;
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      transition: all 0.2s;
      border-radius: 4px;
    }

    .btn-consultar {
      background: #fff;
      color: #000;
      box-shadow: 0 0 20px rgba(255,255,255,0.1);
    }

    .btn-consultar:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 0 30px rgba(255,255,255,0.3);
    }

    .btn-consultar:disabled {
      opacity: 0.5;
      background: #333;
      color: #666;
      cursor: wait;
    }

    .btn-azar {
      background: transparent;
      border: 1px solid var(--border);
      color: #888;
      font-size: 0.8rem;
    }

    .btn-azar:hover {
      border-color: #666;
      color: #fff;
    }

    .btn-download {
      background: #1a1a1a;
      border: 1px solid #333;
      color: #fff;
      margin-top: auto;
    }
    
    .btn-download:hover { background: #222; border-color: #555; }

    /* CANVAS AREA */
    .canvas-container {
      background: #000;
      padding: 3rem;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      /* Patrón de cuadrícula tenue en el fondo del área de visualización */
      background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size: 40px 40px;
    }

    canvas {
      max-width: 100%;
      height: auto !important;
      box-shadow: 0 20px 50px rgba(0,0,0,0.9);
      border: 1px solid #222;
    }

    /* SLIDER PERSONALIZADO */
    input[type=range] {
      -webkit-appearance: none;
      width: 100%;
      background: transparent;
    }
    input[type=range]::-webkit-slider-thumb {
      -webkit-appearance: none;
      height: 16px;
      width: 16px;
      border-radius: 50%;
      background: #fff;
      cursor: pointer;
      margin-top: -6px;
    }
    input[type=range]::-webkit-slider-runnable-track {
      width: 100%;
      height: 4px;
      background: #333;
      border-radius: 2px;
    }

    @media (max-width: 1024px) {
      .oraculo-panel { border-right: none; border-bottom: 1px solid var(--border); }
      .canvas-container { padding: 2rem 1rem; }
    }
  </style>

  <div class="oraculo-wrapper">
    <div class="oraculo-container">
      
      <div class="header-section">
        <h1 class="header-title">Oráculo<br>De La Mente</h1>
        <p class="header-subtitle">/// La Verdad Sin Filtro ///</p>
      </div>

      <div class="system-grid">
        <aside class="oraculo-panel">
          
          <div>
            <label class="label-control">01 // TU INQUIETUD</label>
            <input type="text" id="pregunta" class="oraculo-input" placeholder="Escribe aquí lo que te quita el sueño...">
          </div>

          <div>
            <label class="label-control">02 // LA SENTENCIA</label>
            <textarea id="respuesta" class="oraculo-input" placeholder="Aquí aparecerá la verdad cruda..."></textarea>
          </div>

          <div class="btn-group">
            <button id="btn-consultar" class="oraculo-btn btn-consultar">👁️ Invocar Respuesta</button>
            <button id="btn-azar" class="oraculo-btn btn-azar">⚡ Mensaje Aleatorio</button>
          </div>

          <div style="margin-top: 1rem; border-top: 1px solid #222; padding-top: 1.5rem;">
            <div style="display: flex; gap: 1rem; margin-bottom: 1rem;">
               <div style="flex: 1;">
                 <label class="label-control">FORMATO</label>
                 <select id="format" class="oraculo-input" style="padding: 0.5rem;">
                   <option value="post">CUADRADO (IG)</option>
                   <option value="story">STORY (9:16)</option>
                 </select>
               </div>
               <div style="flex: 1;">
                 <label class="label-control">TAMAÑO</label>
                 <input type="range" id="fontSizeSlider" min="40" max="150" value="80">
               </div>
            </div>
            <button id="btn-download" class="oraculo-btn btn-download">⬇ Guardar Imagen</button>
          </div>

        </aside>

        <section class="canvas-container">
          <canvas id="canvas"></canvas>
        </section>
      </div>

    </div>
  </div>

  <script is:inline>
    // Configuración inicial
    const elements = {
      canvas: document.getElementById('canvas'),
      pregunta: document.getElementById('pregunta'),
      respuesta: document.getElementById('respuesta'),
      format: document.getElementById('format'),
      slider: document.getElementById('fontSizeSlider'),
      btnConsultar: document.getElementById('btn-consultar'),
      btnAzar: document.getElementById('btn-azar'),
      btnDownload: document.getElementById('btn-download')
    };

    const ctx = elements.canvas.getContext('2d');

    // FRASES PRE-CARGADAS (Estilo compa directo)
    const frasesDuras = [
      "LO QUE ESCONDES TE ESTÁ MATANDO. SÁCALO YA.",
      "NO ES MALA SUERTE. ES FALTA DE DISCIPLINA.",
      "ESA PERSONA NO VA A CAMBIAR. TÚ SÍ PUEDES.",
      "LO FÁCIL AHORA TE COSTARÁ AÑOS DE ARREPENTIMIENTO.",
      "ESTÁS ESPERANDO UN MOMENTO PERFECTO QUE NO EXISTE.",
      "TU EGO TE ESTÁ CERRANDO PUERTAS QUE TU TALENTO ABRIÓ.",
      "SI DOLIÓ, FUE PARA QUE DESPERTARAS.",
      "DEJA DE CULPAR A TUS PADRES Y CONSTRUYE TU VIDA."
    ];

    // FUNCIÓN: DIBUJAR RUIDO (Noise)
    function drawNoise(ctx, w, h) {
      const iData = ctx.createImageData(w, h);
      const buffer32 = new Uint32Array(iData.data.buffer);
      const len = buffer32.length;
      for (let i = 0; i < len; i++) {
        if (Math.random() < 0.08) { // Densidad del ruido
          buffer32[i] = 0xffffffff; // Puntos blancos
        }
      }
      
      // Dibujar ruido en un canvas temporal para bajarle opacidad
      const tempCanvas = document.createElement('canvas');
      tempCanvas.width = w;
      tempCanvas.height = h;
      const tempCtx = tempCanvas.getContext('2d');
      tempCtx.putImageData(iData, 0, 0);
      
      ctx.save();
      ctx.globalAlpha = 0.04; // Muy sutil
      ctx.drawImage(tempCanvas, 0, 0);
      ctx.restore();
    }

    // FUNCIÓN PRINCIPAL: RENDER
    const render = () => {
      const w = elements.format.value === 'story' ? 1080 : 1080;
      const h = elements.format.value === 'story' ? 1920 : 1080;
      const fontSize = parseInt(elements.slider.value);
      const text = (elements.respuesta.value || "EL SILENCIO TAMBIÉN ES RESPUESTA").toUpperCase();
      const question = (elements.pregunta.value || "").trim();

      elements.canvas.width = w;
      elements.canvas.height = h;

      // 1. FONDO
      const grad = ctx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w);
      grad.addColorStop(0, '#111');
      grad.addColorStop(1, '#000');
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, w, h);

      // 2. TEXTURA DE RUIDO
      drawNoise(ctx, w, h);

      // 3. MARCOS ESQUINEROS (Estilo Visor)
      ctx.strokeStyle = 'rgba(255, 255, 255, 0.3)';
      ctx.lineWidth = 3;
      const m = 60; // Margen
      const l = 80; // Largo de la línea

      // Esquina Superior Izq
      ctx.beginPath(); ctx.moveTo(m, m+l); ctx.lineTo(m, m); ctx.lineTo(m+l, m); ctx.stroke();
      // Esquina Superior Der
      ctx.beginPath(); ctx.moveTo(w-m-l, m); ctx.lineTo(w-m, m); ctx.lineTo(w-m, m+l); ctx.stroke();
      // Esquina Inferior Izq
      ctx.beginPath(); ctx.moveTo(m, h-m-l); ctx.lineTo(m, h-m); ctx.lineTo(m+l, h-m); ctx.stroke();
      // Esquina Inferior Der
      ctx.beginPath(); ctx.moveTo(w-m-l, h-m); ctx.lineTo(w-m, h-m); ctx.lineTo(w-m, h-m-l); ctx.stroke();

      // 4. PREGUNTA (Fantasmal en el fondo)
      if (question) {
        ctx.fillStyle = 'rgba(255, 255, 255, 0.15)';
        ctx.font = `600 30px 'Inter', sans-serif`;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';
        ctx.letterSpacing = '2px';
        ctx.fillText(question.length > 50 ? question.substring(0,47) + "..." : question, w/2, m + 60);
      }

      // 5. RESPUESTA (Impacto Principal)
      ctx.fillStyle = '#fff';
      ctx.font = `900 ${fontSize}px 'Space Grotesk', sans-serif`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.shadowColor = "rgba(255, 255, 255, 0.4)";
      ctx.shadowBlur = 20;

      // Wrap text logic
      const words = text.split(' ');
      let lines = [];
      let currentLine = words[0];
      const maxWidth = w - (m * 4);

      for (let i = 1; i < words.length; i++) {
        const testLine = currentLine + " " + words[i];
        if (ctx.measureText(testLine).width < maxWidth) {
          currentLine = testLine;
        } else {
          lines.push(currentLine);
          currentLine = words[i];
        }
      }
      lines.push(currentLine);

      const lineHeight = fontSize * 1.1;
      const totalHeight = lines.length * lineHeight;
      const startY = (h/2) - (totalHeight/2) + (lineHeight/2);

      lines.forEach((line, index) => {
        ctx.fillText(line, w/2, startY + (index * lineHeight));
      });
      
      // Reset Shadow
      ctx.shadowBlur = 0;

      // 6. FIRMA
      ctx.fillStyle = '#444';
      ctx.font = `bold 24px 'JetBrains Mono', monospace`;
      ctx.textBaseline = 'bottom';
      ctx.fillText("ORÁCULO DE LA MENTE", w/2, h - m - 20);
    };

    // LOGICA DE LLAMADA A IA
    const callGemini = async () => {
      const pregunta = elements.pregunta.value.trim();
      if (!pregunta) return alert("El silencio no trae respuestas. Escribe algo.");

      elements.btnConsultar.disabled = true;
      elements.btnConsultar.innerText = "🔮 CONECTANDO...";
      
      // PROMPT DURO Y DIRECTO
      const promptSystem = `
        ERES UN AMIGO SABIO, DIRECTO Y SIN FILTRO. NO ERES UN ASISTENTE VIRTUAL.
        TU OBJETIVO: Dar una lección de vida dura pero necesaria basada en la pregunta: "${pregunta}".
        
        REGLAS:
        1. RESPONDE EN MAYÚSCULAS SOSTENIDAS.
        2. MÁXIMO 15 PALABRAS. TIENE QUE SER UNA SENTENCIA CORTA.
        3. NO USES PALABRAS REBUSCADAS. HABLA CLARO.
        4. NO JUZGUES, PERO NO TENGAS PIEDAD CON LA VERDAD.
        5. SI PREGUNTA POR AMOR TÓXICO: Dile que se valore.
        6. SI PREGUNTA POR MIEDO: Dile que actúe.
        
        EJEMPLO DE TONO:
        - "YA SABES QUE NO TE CONVIENE. DEJA DE HACERTE EL CIEGO."
        - "EL MIEDO TE ESTÁ ROBANDO LA VIDA QUE DICES QUERER."
      `;

      try {
        // AQUÍ VA TU LLAMADA A TU API DE WORKER O BACKEND
        // Simularé la llamada para el diseño:
        const response = await fetch('https://mis-frases.poderparatriunfar.workers.dev/', {
             method: 'POST',
             headers: { 'Content-Type': 'application/json' },
             body: JSON.stringify({ prompt: promptSystem }),
        });
        const data = await response.json();
        
        elements.respuesta.value = data.text.toUpperCase();
        render();

      } catch (e) {
        console.error(e);
        elements.respuesta.value = "LA CONEXIÓN FALLÓ, PERO TU INTUICIÓN YA SABE LA RESPUESTA.";
        render();
      } finally {
        elements.btnConsultar.disabled = false;
        elements.btnConsultar.innerText = "👁️ INVOCAR RESPUESTA";
      }
    };

    // EVENT LISTENERS
    elements.respuesta.addEventListener('input', render);
    elements.pregunta.addEventListener('input', render);
    elements.slider.addEventListener('input', render);
    elements.format.addEventListener('change', render);
    
    elements.btnConsultar.addEventListener('click', callGemini);
    
    elements.btnAzar.addEventListener('click', () => {
      elements.respuesta.value = frasesDuras[Math.floor(Math.random() * frasesDuras.length)];
      render();
    });

    elements.btnDownload.addEventListener('click', () => {
      const link = document.createElement('a');
      link.download = `ORACULO-${Date.now()}.png`;
      link.href = elements.canvas.toDataURL();
      link.click();
    });

    // Render inicial
    window.addEventListener('load', render);
    render();

  </script>
</Layout>