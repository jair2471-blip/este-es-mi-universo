---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'ANTONOV PRO | Elite Mindset',
  description: 'La conciencia artificial de los líderes.',
};
---

<Layout metadata={metadata}>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;700;900&family=Space+Grotesk:wght@700&display=swap');

    /* 🔥 CORRECCIÓN: Contenedor que respeta el menú 🔥 */
    .stage-area {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 90vh; /* Ocupa la pantalla pero deja respirar al menú */
      padding: 40px 20px;
      
      /* Fondo integrado aquí para no afectar el header global */
      background: #050505;
      background-image: 
        radial-gradient(at 0% 0%, rgba(255, 215, 0, 0.03) 0px, transparent 50%),
        radial-gradient(at 100% 100%, rgba(255, 255, 255, 0.01) 0px, transparent 50%);
    }

    .app-window {
      width: 100%;
      max-width: 1000px;
      background: #0a0a0a;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 40px 80px rgba(0,0,0,0.8);
      display: flex;
      flex-direction: column;
      position: relative;
      z-index: 10; /* Elevado, pero no tanto como para tapar un menú dropdown */
    }

    .app-bar {
      height: 45px;
      padding: 0 20px;
      background: rgba(255, 255, 255, 0.03);
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }

    .window-controls {
      position: absolute;
      left: 20px;
      display: flex;
      gap: 8px;
    }
    
    .dot { width: 10px; height: 10px; border-radius: 50%; background: #333; }
    .dot.close { background: #ff5f56; }
    .dot.min { background: #ffbd2e; }
    .dot.max { background: #27c93f; }

    .app-title {
      color: #555;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      font-family: 'Space Grotesk', sans-serif;
    }

    /* Grilla responsiva */
    .system-grid {
      display: grid;
      grid-template-columns: 1fr;
    }

    @media (min-width: 900px) {
      .system-grid { grid-template-columns: 340px 1fr; }
    }

    /* Panel de Control (Izquierda) */
    .side-panel {
      padding: 30px;
      border-right: 1px solid rgba(255, 255, 255, 0.05);
      background: #0c0c0c;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .brand h1 { font-family: 'Bebas Neue', cursive; font-size: 3rem; color: #fff; margin: 0; line-height: 0.9; }
    .brand p { color: #ffd700; font-size: 0.6rem; letter-spacing: 2px; font-weight: 700; margin-top: 5px; opacity: 0.8; }

    .control-group { display: flex; flex-direction: column; gap: 8px; }
    .control-group label { color: #666; font-size: 0.6rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; }

    textarea, select, input[type="range"] {
      background: #111;
      border: 1px solid #222;
      border-radius: 8px;
      color: #ddd;
      padding: 12px;
      font-size: 0.85rem;
      font-family: 'Inter', sans-serif;
      transition: border 0.3s;
    }
    textarea:focus { outline: none; border-color: #ffd700; background: #141414; }

    .btn-action {
      background: #fff;
      color: #000;
      border: none;
      padding: 14px;
      border-radius: 8px;
      font-weight: 900;
      text-transform: uppercase;
      cursor: pointer;
      transition: 0.2s;
      letter-spacing: 1px;
      font-size: 0.9rem;
    }
    .btn-action:hover { background: #ffd700; transform: translateY(-1px); }

    /* Área de Previsualización (Derecha) */
    .preview-box {
      background: #000;
      padding: 30px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: relative;
    }

    canvas {
      max-width: 100%;
      height: auto;
      border-radius: 6px;
      box-shadow: 0 20px 50px rgba(0,0,0,0.7);
      border: 1px solid #1a1a1a;
    }

    .loading-pulse { opacity: 0.7; pointer-events: none; }
  </style>

  <div class="stage-area">
    
    <div class="app-window">
      <div class="app-bar">
        <div class="window-controls">
          <div class="dot close"></div>
          <div class="dot min"></div>
          <div class="dot max"></div>
        </div>
        <span class="app-title">ANTONOV CORE SYSTEM v2.2</span>
      </div>

      <div class="system-grid">
        <aside class="side-panel">
  <div class="brand">
    <h1>ANTONOV</h1>
    <p>SISTEMA DE EXCELENCIA</p>
  </div>

  <div class="control-group">
    <label>Situación Actual</label>
    <textarea id="in-pregunta" rows="3" placeholder="¿Qué te detiene, líder?"></textarea>
  </div>

  <button id="run-btn" class="btn-action">EJECUTAR SENTENCIA</button>

  <hr style="border:0; border-top:1px solid #1a1a1a; margin: 5px 0;">

  <div class="control-group">
    <label>Formato de Salida</label>
    <select id="in-format">
      <option value="post">CUADRADO (IG FEED)</option>
      <option value="story">VERTICAL (IG STORY)</option>
    </select>
  </div>

  <div class="control-group">
    <div style="display:flex; justify-content:space-between;">
       <label>Tamaño Texto</label>
       <span id="txt-val" style="font-size:0.6rem; color:#666;">100%</span>
    </div>
    <input type="range" id="in-size" min="50" max="180" value="100">
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 10px;">
    <button id="share-btn" class="btn-action" style="background: #25D366; color: white; font-size: 0.7rem; padding: 10px;">COMPARTIR</button>
    <button id="ig-btn" class="btn-action" style="background: linear-gradient(45deg, #f09433 0%, #dc2743 50%, #bc1888 100%); color: white; font-size: 0.7rem; padding: 10px;">IG STORY</button>
  </div>

  <button id="dl-btn" style="background:transparent; border:1px solid #333; color:#666; margin-top:10px;" class="btn-action">DESCARGAR ARTE</button>
</aside>

        <main class="preview-box">
          <canvas id="main-canvas"></canvas>
          <input type="hidden" id="hidden-res">
        </main>
      </div>
    </div>
  
  </div>

  <script is:inline>
    function startSystem() {
      const canvas = document.getElementById('main-canvas');
      const ctx = canvas.getContext('2d');
      // Dentro de startSystem(), donde defines 'ui', agrega estos:
const ui = {
  // ... sus elementos anteriores ...
  shareBtn: document.getElementById('share-btn'),
  igBtn: document.getElementById('ig-btn'),
  dl: document.getElementById('dl-btn'),
  canvas: document.getElementById('main-canvas')
};

// Lógica para COMPARTIR IMAGEN
ui.shareBtn.onclick = async () => {
  try {
    const dataUrl = ui.canvas.toDataURL('image/png');
    const blob = await (await fetch(dataUrl)).blob();
    const file = new File([blob], 'antonov-sentencia.png', { type: 'image/png' });

    if (navigator.share) {
      await navigator.share({
        files: [file],
        title: 'Antonov Sentencia',
        text: 'Mira esta verdad cruda.',
      });
    } else {
      alert("Compa, tu navegador no permite compartir directo. ¡Usa Descargar!");
    }
  } catch (err) {
    console.error("Error al compartir:", err);
  }
};

// Lógica para IG STORY (Simplemente descarga y avisa)
ui.igBtn.onclick = () => {
  alert("Descargando... ¡Súbela a tus Stories, líder!");
  ui.dl.click();
};

      const render = () => {
        const isStory = ui.fmt.value === 'story';
        const w = 1080;
        const h = isStory ? 1920 : 1080;
        canvas.width = w; canvas.height = h;

        // 1. FONDO NEGRO PURO
        ctx.fillStyle = '#000';
        ctx.fillRect(0, 0, w, h);

        // 2. TEXTURA SUTIL
        for(let i=0; i<8000; i++){
          ctx.fillStyle = `rgba(255,255,255,${Math.random()*0.025})`;
          ctx.fillRect(Math.random()*w, Math.random()*h, 2, 2);
        }

        // 3. PREGUNTA (CONTEXTO)
        const qText = ui.q.value.trim().toUpperCase();
        if(qText) {
          ctx.font = "italic 600 30px 'Inter'";
          ctx.fillStyle = "rgba(255,255,255,0.4)";
          ctx.textAlign = "center";
          // Ajuste de posición vertical
          drawWrappedText(ctx, qText, w/2, 130, w*0.8, 40, false);
        }

        // 4. RESPUESTA (ANTONOV)
        const rText = (ui.r.value || "SISTEMA LISTO. ESPERANDO DATOS...").toUpperCase();
        const fSize = parseInt(ui.sz.value);
        
        ctx.font = `900 ${fSize}px 'Bebas Neue'`;
        ctx.fillStyle = "#fff";
        ctx.textAlign = "center";
        
        // Centrado matemático
        drawWrappedText(ctx, rText, w/2, h/2, w*0.85, fSize * 1.05, true);

        // 5. MARCA DE AGUA
        ctx.font = "700 22px 'Inter'";
        ctx.fillStyle = "#ffd700";
        ctx.letterSpacing = "10px";
        ctx.fillText("EL UNIVERSO DE LA MENTE", w/2, h - 90);
      };

      // Función maestra de texto
      function drawWrappedText(context, text, x, y, maxWidth, lineHeight, centerV) {
        const words = text.split(' ');
        let lines = [];
        let currentLine = '';

        for (let n = 0; n < words.length; n++) {
          let testLine = currentLine + words[n] + ' ';
          let metrics = context.measureText(testLine);
          if (metrics.width > maxWidth && n > 0) {
            lines.push(currentLine);
            currentLine = words[n] + ' ';
          } else { currentLine = testLine; }
        }
        lines.push(currentLine);

        let startY = centerV ? y - ((lines.length - 1) * lineHeight) / 2 : y;
        lines.forEach(line => {
          context.fillText(line.trim(), x, startY);
          startY += lineHeight;
        });
      }

      // Lógica del botón
      ui.btn.onclick = async () => {
        if(!ui.q.value) return alert("¡Sin datos no hay diagnóstico!");
        
        const originalText = ui.btn.innerText;
        ui.btn.innerText = "PROCESANDO...";
        ui.btn.classList.add('loading-pulse');
        ui.btn.disabled = true;

        try {
          const res = await fetch('https://mis-frases.poderparatriunfar.workers.dev/', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ 
                prompt: `Actúa como Antonov (Estilo rudo de Miguel Ángel Cornejo). Contexto: "${ui.q.value}". Dame 2 frases cortas y contundentes en MAYÚSCULAS. Que duelan pero motiven.`
            })
          });
          const data = await res.json();
          ui.r.value = data.text;
          render();
        } catch (e) { 
            alert("Error de conexión con el núcleo."); 
        } finally {
          ui.btn.innerText = originalText;
          ui.btn.classList.remove('loading-pulse');
          ui.btn.disabled = false;
        }
      };

      ui.sz.oninput = () => { ui.szLabel.innerText = ui.sz.value + '%'; render(); };
      ui.fmt.onchange = render;
      
      ui.dl.onclick = () => {
        const link = document.createElement('a');
        link.download = `ANTONOV_${Date.now()}.png`;
        link.href = canvas.toDataURL('image/png');
        link.click();
      };

      // Render inicial
      render();
    }

    document.addEventListener('astro:page-load', startSystem);
    startSystem();
  </script>
</Layout>