---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'ANTONOV V5.0 | Núcleo de Personalidades',
  description: 'Sistema robusto de diseño industrial impulsado por IA.',
};
---

<Layout metadata={metadata}>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;900&family=Space+Mono:wght@400;700&display=swap');

    .antonov-wrapper {
      max-width: 1000px; /* CAMBIO: Reducido de 1400px a 1000px para centrarlo */
      margin: 4rem auto; /* CAMBIO: Más margen arriba/abajo para que respire */
      padding: 0 1.5rem;
    }

    .antonov-container {
      background: #050505;
      border: 1px solid #333; /* CAMBIO: Borde más sutil */
      border-radius: 12px;
      padding: 2rem;
      box-shadow: 0 30px 80px rgba(0, 0, 0, 0.7); /* Sombra más dramática */
    }

    .antonov-body {
      color: white;
      font-family: 'Inter', sans-serif;
    }

    .header-section {
      text-align: center;
      margin-bottom: 2rem;
      border-bottom: 1px solid #222;
      padding-bottom: 1.5rem;
    }

    .header-title {
      font-size: clamp(1.8rem, 4vw, 2.5rem); /* Título un poco más compacto */
      font-weight: 900;
      color: #22c55e;
      font-style: italic;
      text-transform: uppercase;
      line-height: 1;
      margin-bottom: 0.5rem;
    }

    .header-subtitle {
      color: #ea580c;
      font-weight: bold;
      letter-spacing: 2px;
      font-size: 0.7rem;
      text-transform: uppercase;
    }

    .voice-name-display {
      color: #fff;
      font-weight: 900;
    }

    .system-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    @media (min-width: 1024px) {
      .system-grid {
        grid-template-columns: 320px 1fr; /* Panel de control ajustado */
      }
    }

    .antonov-panel {
      background: #0a0a0a;
      border: 1px solid #222;
      padding: 1.5rem;
      border-radius: 8px;
      height: fit-content;
    }

    .control-group {
      margin-bottom: 1.25rem;
    }

    .label-control {
      color: #666;
      font-weight: bold;
      font-size: 0.65rem;
      display: block;
      margin-bottom: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .label-voice {
      color: #ea580c;
    }

    .antonov-input {
      width: 100%;
      background: #111;
      border: 1px solid #333;
      color: white;
      padding: 0.75rem;
      font-family: 'Space Mono', monospace;
      font-size: 0.8rem;
      outline: none;
      border-radius: 4px;
      transition: border-color 0.3s;
    }

    .antonov-input:focus {
      border-color: #ea580c;
    }

    textarea.antonov-input {
      resize: vertical;
      min-height: 80px;
    }

    .voice-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 0.5rem;
    }

    .v-btn {
      background: #111;
      border: 2px solid #222;
      padding: 0;
      height: 50px; /* Altura fija para botones uniformes */
      cursor: pointer;
      font-size: 1.2rem;
      filter: grayscale(1);
      transition: all 0.3s;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 6px;
    }

    .v-btn:hover {
      border-color: #444;
      transform: translateY(-2px);
    }

    .v-btn.active {
      border-color: #ea580c;
      background: #1a1a1a;
      filter: grayscale(0);
      transform: scale(1.05);
      box-shadow: 0 0 15px rgba(234, 88, 12, 0.2);
    }

    .antonov-btn {
      width: 100%;
      padding: 0.9rem;
      font-weight: 900;
      text-transform: uppercase;
      cursor: pointer;
      border: none;
      transition: all 0.2s;
      font-size: 0.7rem;
      letter-spacing: 1.5px;
      border-radius: 4px;
      font-family: 'Inter', sans-serif;
    }

    .btn-gemini {
      background: #27272a;
      color: #ea580c;
      margin-bottom: 0.5rem;
      border: 1px solid #ea580c;
    }

    .btn-gemini:hover:not(:disabled) {
      background: #ea580c;
      color: black;
    }

    .btn-random {
      background: transparent;
      border: 1px solid #333;
      color: #888;
    }

    .btn-random:hover {
      border-color: #666;
      color: white;
    }

    .btn-download {
      background: #ea580c;
      color: black;
      margin-top: 1rem;
    }

    .btn-download:hover {
      background: #fff;
      transform: translateY(-2px);
    }

    .antonov-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .canvas-container {
      background: #020202;
      border: 1px solid #222;
      padding: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 400px;
      border-radius: 8px;
    }

    canvas {
      max-width: 100%;
      height: auto !important;
      border: 1px solid #333;
      box-shadow: 0 0 40px rgba(0, 0, 0, 0.5);
    }

    .slider-container {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .slider-container input {
      flex: 1;
      accent-color: #ea580c;
    }

    .size-display {
      font-family: 'Space Mono', monospace;
      color: #ea580c;
      font-weight: bold;
      min-width: 50px;
      text-align: right;
      font-size: 0.8rem;
    }

    .divider {
      border-top: 1px solid #222;
      padding-top: 1.25rem;
      margin-top: 0.5rem;
    }

    select.antonov-input {
      margin-bottom: 0.5rem;
    }
  </style>

  <div class="antonov-wrapper">
    <div class="antonov-container">
      <section class="antonov-body">
        <div class="header-section">
          <h1 class="header-title">ANTONOV V5.0</h1>
          <p class="header-subtitle">
            SISTEMA MULTI-NÚCLEO // <span id="current-voice-name" class="voice-name-display">SAPO HONESTO</span>
          </p>
        </div>

        <div class="system-grid">
          <aside class="antonov-panel">
            <div class="control-group">
              <label class="label-control label-voice">◢ SELECCIONAR NÚCLEO:</label>
              <div class="voice-grid">
                <button class="v-btn active" data-voice="sapo" title="Sapo Honesto">🐸</button>
                <button class="v-btn" data-voice="coach" title="Coach Sin Azúcar">🥊</button>
                <button class="v-btn" data-voice="zen" title="Zen Callejero">🕶️</button>
                <button class="v-btn" data-voice="bufon" title="Bufón Filosófico">🃏</button>
                <button class="v-btn" data-voice="abuela" title="Abuela Sabia">👵</button>
              </div>
            </div>

            <div class="control-group">
              <label class="label-control">▸ Texto del Núcleo:</label>
              <textarea id="quote" class="antonov-input" placeholder="SISTEMA LISTO..."></textarea>
            </div>

            <div class="control-group">
              <button id="btn-gemini" class="antonov-btn btn-gemini">
                <span id="btn-text">🤖 GENERAR CON GEMINI</span>
              </button>
              <button id="btn-random" class="antonov-btn btn-random">🎲 FRASE ALEATORIA</button>
            </div>

            <div class="control-group divider">
              <label class="label-control">▸ Tamaño de Fuente:</label>
              <div class="slider-container">
                <input type="range" id="fontSizeSlider" min="20" max="300" value="80" />
                <span id="sizeVal" class="size-display">80px</span>
              </div>
            </div>

            <div class="control-group">
              <label class="label-control">▸ Formato:</label>
              <select id="format" class="antonov-input">
                <option value="post">CUADRADO (1080x1080)</option>
                <option value="story">STORY (1080x1920)</option>
                <option value="banner">BANNER (1920x1080)</option>
              </select>

              <label class="label-control" style="margin-top: 0.5rem">▸ Intensidad Glitch:</label>
              <select id="intensity" class="antonov-input">
                <option value="0.5">BAJO</option>
                <option value="1.0" selected>ALTO</option>
                <option value="1.5">EXTREMO</option>
              </select>
            </div>

            <button id="btn-download" class="antonov-btn btn-download">⬇ DESCARGAR IMAGEN</button>
          </aside>

          <section class="canvas-container">
            <canvas id="canvas"></canvas>
          </section>
        </div>
      </section>
    </div>
  </div>

  <script is:inline>
    // IMPORTANTE: Usamos 'astro:page-load' para que funcione al navegar entre páginas
    document.addEventListener('astro:page-load', () => {
      const canvas = document.getElementById('canvas');
      if (!canvas) return; // Si no estamos en la página correcta, no hace nada
      
      const ctx = canvas.getContext('2d');

      const el = {
        format: document.getElementById('format'),
        quote: document.getElementById('quote'),
        intensity: document.getElementById('intensity'),
        slider: document.getElementById('fontSizeSlider'),
        sizeVal: document.getElementById('sizeVal'),
        btnGemini: document.getElementById('btn-gemini'),
        btnText: document.getElementById('btn-text'),
        btnRandom: document.getElementById('btn-random'),
        btnDownload: document.getElementById('btn-download'),
        voiceButtons: document.querySelectorAll('[data-voice]'),
        voiceName: document.getElementById('current-voice-name'),
      };

      const personalidades = {
        sapo: {
          nombre: 'SAPO HONESTO',
          color: '#22c55e',
          prompt:
            'Eres el SAPO HONESTO. Tu misión es dar una lección brutal sobre realidad financiera o éxito personal. NO uses clichés. Genera una frase de 10 a 14 palabras. La estructura debe ser: "Verdad dura + Consecuencia lógica". Ejemplo: "SI GASTAS DINERO QUE NO TIENES EN COSAS QUE NO NECESITAS, TERMINARÁS TRABAJANDO PARA QUIEN SÍ AHORRÓ". Todo en MAYÚSCULAS.',
          frases: [
            'EL DINERO NO CAMBIA A LAS PERSONAS SOLO LAS DELATA FRENTE A LOS DEMÁS',
            'TU SALARIO ES EL SOBORNO QUE TE DAN PARA QUE OLVIDES TUS PROPIOS SUEÑOS',
            'SI BUSCAS A LA PERSONA QUE CAMBIARÁ TU VIDA MÍRATE AL ESPEJO Y DEJA DE LLORAR',
            'LA POBREZA NO SE SOLUCIONA CON DINERO SE SOLUCIONA CON EDUCACIÓN Y CARÁCTER',
            'MIENTRAS TÚ DUERMES SOÑANDO CON EL ÉXITO OTROS ESTÁN DESPIERTOS CONSTRUYÉNDOLO',
          ],
        },
        coach: {
          nombre: 'COACH SIN AZÚCAR',
          color: '#ef4444',
          prompt:
            'Eres el COACH SIN AZÚCAR. Enseña disciplina estoica. No motives, EXIGE. Genera una frase de 10 a 14 palabras. La idea es: "El dolor de hoy es la victoria de mañana". Ejemplo: "EL DOLOR DE LA DISCIPLINA PESA ONZAS PERO EL DOLOR DEL ARREPENTIMIENTO PESA TONELADAS". Todo en MAYÚSCULAS.',
          frases: [
            'NO TE DETENGAS CUANDO ESTÉS CANSADO DETENTE SOLAMENTE CUANDO HAYAS TERMINADO',
            'LA COMODIDAD ES UNA DROGA LENTA QUE MATA TUS AMBICIONES SIN QUE TE DES CUENTA',
            'SI NO ESTÁS DISPUESTO A SACRIFICAR LO USUAL TENDRÁS QUE CONFORMARTE CON UNA VIDA ORDINARIA',
            'TU CUERPO PUEDE AGUANTAR CASI CUALQUIER COSA ES TU MENTE A LA QUE TIENES QUE CONVENCER',
            'EL TALENTO TE ABRE LA PUERTA PERO SOLO LA OBSESIÓN TE MANTIENE DENTRO DE LA HABITACIÓN',
          ],
        },
        zen: {
          nombre: 'ZEN CALLEJERO',
          color: '#a855f7',
          prompt:
            'Eres el ZEN CALLEJERO. Mezcla filosofía profunda con realidad urbana. Genera una frase de 10 a 14 palabras sobre el control mental y la paz en el caos. Ejemplo: "NO ES EL TRÁFICO LO QUE TE ESTRESA ES TU INCAPACIDAD DE ACEPTAR QUE NO TIENES EL CONTROL". Todo en MAYÚSCULAS.',
          frases: [
            'A VECES LA MEJOR RESPUESTA ES EL SILENCIO Y LA MEJOR VENGANZA ES SONREÍR Y SEGUIR',
            'LO QUE NIEGAS TE SOMETE LO QUE ACEPTAS TE TRANSFORMA Y TE HACE LIBRE DE VERDAD',
            'NO PUEDES CALMAR LA TORMENTA PERO PUEDES CALMARTE A TI MISMO MIENTRAS LA TORMENTA PASA',
            'PREOCUPARSE ES COMO CAMINAR CON PARAGUAS ABIERTO ESPERANDO A QUE LLUEVA DENTRO DE TU CASA',
            'QUIEN TE ENFADA TE DOMINA NO LE ENTREGUES EL CONTROL REMOTO DE TUS EMOCIONES A NADIE',
          ],
        },
        bufon: {
          nombre: 'BUFÓN FILOSÓFICO',
          color: '#eab308',
          prompt:
            'Eres el BUFÓN FILOSÓFICO. Usa sarcasmo inteligente para criticar la falsedad de la sociedad moderna. Genera una frase de 10 a 14 palabras. Revela una paradoja irónica. Ejemplo: "COMPRAMOS COSAS QUE NO QUEREMOS CON DINERO QUE NO TENEMOS PARA IMPRESIONAR A GENTE QUE NO NOS IMPORTA". Todo en MAYÚSCULAS.',
          frases: [
            'VIVIMOS EN UN MUNDO DONDE EL FUNERAL IMPORTA MÁS QUE EL MUERTO Y LA BODA MÁS QUE EL AMOR',
            'TE ENDEUDASTE 36 MESES POR UN TELÉFONO PARA QUE VEAN QUE ERES RICO GENTE QUE NI TE CONOCE',
            'ERES LIBRE DE HACER LO QUE QUIERAS SIEMPRE Y CUANDO HAGAS EXACTAMENTE LO QUE EL ALGORITMO TE DIGA',
            'LA GENTE SUBE FOTOS DE SUS LIBROS PERO RARA VEZ SUBE FOTOS DE LO QUE APRENDIÓ DE ELLOS',
            'BUSCAMOS APLAUSOS DE EXTRAÑOS EN INTERNET MIENTRAS IGNORAMOS A QUIENES NOS APLAUDEN EN LA SALA',
          ],
        },
        abuela: {
          nombre: 'ABUELA SABIA',
          color: '#3b82f6',
          prompt:
            'Eres la ABUELA SABIA. Das consejos de vida basados en la experiencia y los valores antiguos. Genera una frase de 10 a 14 palabras. Enfócate en la paciencia, la siembra y la cosecha. Ejemplo: "NO PUEDES EXIGIRLE FRUTOS AL ÁRBOL SI NUNCA TE TOMASTE EL TIEMPO DE REGAR SUS RAÍCES". Todo en MAYÚSCULAS.',
          frases: [
            'CUIDADO CON LO QUE DICES CUANDO ESTÁS ENOJADO PORQUE EL PERDÓN NO BORRA LA MEMORIA',
            'NO TE JUNTES CON QUIEN TE CORTA LAS ALAS SOLO POR MIEDO A VOLAR SOLO',
            'LA MENTIRA TIENE PATAS CORTAS PERO LA VERDAD SIEMPRE ALCANZA AL QUE CORRE DE ELLA',
            'VALORA A QUIEN TE BUSCA CUANDO NO TE NECESITA PORQUE ESOS SON LOS QUE DE VERDAD TE QUIEREN',
            'NO SIEMBRES VIENTOS DE ODIO SI NO TIENES UN TECHO FUERTE PARA AGUANTAR LA TORMENTA',
          ],
        },
      };

      let selectedVoice = 'sapo';

      const render = () => {
        const format = el.format.value;
        const text = (el.quote.value || 'SISTEMA LISTO').toUpperCase();
        const intensity = parseFloat(el.intensity.value || 1.0);
        const fontSize = parseInt(el.slider.value || 80);
        const per = personalidades[selectedVoice];
        if (el.sizeVal) el.sizeVal.innerText = fontSize + 'px';

        let w = 1080,
          h = 1080;
        if (format === 'story') {
          w = 1080;
          h = 1920;
        }
        if (format === 'banner') {
          w = 1920;
          h = 1080;
        }
        canvas.width = w;
        canvas.height = h;

        ctx.fillStyle = '#000';
        ctx.fillRect(0, 0, w, h);
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.font = `900 ${fontSize}px monospace`;

        const words = text.split(' ');
        let lines = [],
          currentLine = words[0];
        for (let i = 1; i < words.length; i++) {
          if (ctx.measureText(currentLine + ' ' + words[i]).width < w * 0.85) {
            currentLine += ' ' + words[i];
          } else {
            lines.push(currentLine);
            currentLine = words[i];
          }
        }
        lines.push(currentLine);

        const lineHeight = fontSize * 1.15;
        const totalHeight = lines.length * lineHeight;
        const startY = h / 2 - totalHeight / 2 + fontSize / 2;

        lines.forEach((line, i) => {
          const y = startY + i * lineHeight;
          const offset = 8 * intensity;
          ctx.fillStyle = 'rgba(255, 0, 0, 0.7)';
          ctx.fillText(line, w / 2 + offset, y);
          ctx.fillStyle = 'rgba(0, 255, 255, 0.7)';
          ctx.fillText(line, w / 2 - offset, y);
          ctx.fillStyle = '#fff';
          ctx.fillText(line, w / 2, y);
        });

        ctx.strokeStyle = per.color;
        ctx.lineWidth = 12;
        ctx.strokeRect(25, 25, w - 50, h - 50);
        ctx.fillStyle = per.color;
        ctx.font = `bold ${w * 0.025}px monospace`;
        ctx.fillText(`>>> ${per.nombre} <<<`, w / 2, h - 60);
      };

      const callGemini = async () => {
        const per = personalidades[selectedVoice];
        el.btnGemini.disabled = true;
        el.btnText.textContent = '⏳ GENERANDO...';
        try {
          const response = await fetch('https://mis-frases.poderparatriunfar.workers.dev/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ prompt: per.prompt }),
          });
          const data = await response.json();
          if (!response.ok) throw new Error(data.error || `Error ${response.status}`);
          el.quote.value = data.text.toUpperCase();
          render();
        } catch (error) {
          console.error('Error:', error);
          alert(`❌ Error: ${error.message}`);
        } finally {
          el.btnGemini.disabled = false;
          el.btnText.textContent = '🤖 GENERAR CON GEMINI';
        }
      };

      el.voiceButtons.forEach((btn) => {
        btn.onclick = (e) => {
          e.preventDefault();
          el.voiceButtons.forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          selectedVoice = btn.getAttribute('data-voice');
          if (el.voiceName) el.voiceName.innerText = personalidades[selectedVoice].nombre;
          render();
        };
      });

      [el.format, el.intensity, el.slider, el.quote].forEach((input) => {
        if (input) input.oninput = render;
      });

      el.btnGemini.onclick = callGemini;

      el.btnRandom.onclick = () => {
        const frases = personalidades[selectedVoice].frases;
        el.quote.value = frases[Math.floor(Math.random() * frases.length)];
        render();
      };

      el.btnDownload.onclick = () => {
        const link = document.createElement('a');
        link.download = `ANTONOV-${selectedVoice}-${Date.now()}.png`;
        link.href = canvas.toDataURL();
        link.click();
      };

      // Renderizado inicial
      render();
    });
  </script>
</Layout>