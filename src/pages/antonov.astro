---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'ANTONOV PRO | Elite Mindset',
  description: 'La conciencia artificial de los líderes.',
};
---

<Layout metadata={metadata}>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;700;900&display=swap');

    * { box-sizing: border-box; }

    .stage-area {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 90vh;
      padding: 20px;
      background: radial-gradient(ellipse at center, #0a0a0a 0%, #000000 100%);
      position: relative;
    }

    /* Efecto de partículas de fondo */
    .stage-area::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-image: 
        radial-gradient(2px 2px at 20% 30%, rgba(255, 215, 0, 0.15), transparent),
        radial-gradient(2px 2px at 60% 70%, rgba(255, 255, 255, 0.1), transparent),
        radial-gradient(1px 1px at 50% 50%, rgba(255, 215, 0, 0.1), transparent);
      background-size: 200px 200px, 300px 300px, 150px 150px;
      animation: particleFloat 20s linear infinite;
      pointer-events: none;
    }

    @keyframes particleFloat {
      from { background-position: 0 0, 0 0, 0 0; }
      to { background-position: 200px 200px, -300px 300px, 150px -150px; }
    }

    .app-window {
      width: 100%;
      max-width: 1000px;
      background: linear-gradient(135deg, #0a0a0a 0%, #0d0d0d 100%);
      border: 1px solid rgba(255, 215, 0, 0.2);
      border-radius: 24px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      box-shadow: 
        0 50px 100px rgba(0,0,0,0.9),
        0 0 0 1px rgba(255, 215, 0, 0.1),
        inset 0 1px 0 rgba(255, 255, 255, 0.05);
      position: relative;
      z-index: 1;
    }

    .app-bar {
      height: 50px;
      padding: 0 20px;
      background: linear-gradient(to bottom, rgba(255, 215, 0, 0.05), transparent);
      border-bottom: 1px solid rgba(255, 215, 0, 0.15);
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }

    .app-bar::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255, 215, 0, 0.3), transparent);
    }

    .app-title { 
      color: #888; 
      font-size: 0.65rem; 
      font-weight: 700; 
      letter-spacing: 3px;
      text-shadow: 0 0 20px rgba(255, 215, 0, 0.2);
    }

    .system-grid { display: grid; grid-template-columns: 1fr; }
    @media (min-width: 900px) { .system-grid { grid-template-columns: 340px 1fr; } }

    .side-panel {
      padding: 35px;
      border-right: 1px solid rgba(255, 215, 0, 0.1);
      background: linear-gradient(to bottom, #0a0a0a, #080808);
      display: flex;
      flex-direction: column;
      gap: 18px;
      position: relative;
    }

    .side-panel::before {
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      width: 1px;
      height: 100%;
      background: linear-gradient(to bottom, transparent, rgba(255, 215, 0, 0.3), transparent);
    }

    .brand { 
      padding-bottom: 15px;
      border-bottom: 2px solid rgba(255, 215, 0, 0.2);
      margin-bottom: 10px;
    }
    .brand h1 { 
      font-family: 'Bebas Neue', cursive; 
      font-size: 3.2rem; 
      color: #fff; 
      margin: 0;
      text-shadow: 0 0 30px rgba(255, 215, 0, 0.3);
      letter-spacing: 2px;
    }
    .brand p { 
      color: #ffd700; 
      font-size: 0.6rem; 
      letter-spacing: 3px; 
      font-weight: 700;
      margin-top: 5px;
      text-shadow: 0 0 10px rgba(255, 215, 0, 0.5);
    }

    .control-group { display: flex; flex-direction: column; gap: 10px; }
    .control-group label { 
      color: #888; 
      font-size: 0.6rem; 
      font-weight: 800; 
      text-transform: uppercase;
      letter-spacing: 1.5px;
    }

    textarea, select {
      background: linear-gradient(to bottom, #0d0d0d, #0a0a0a);
      border: 1px solid rgba(255, 215, 0, 0.15);
      border-radius: 10px;
      color: #fff;
      padding: 14px;
      font-size: 0.85rem;
      transition: all 0.3s ease;
      box-shadow: inset 0 2px 8px rgba(0, 0, 0, 0.5);
    }

    textarea:focus, select:focus {
      outline: none;
      border-color: rgba(255, 215, 0, 0.4);
      box-shadow: 
        inset 0 2px 8px rgba(0, 0, 0, 0.5),
        0 0 20px rgba(255, 215, 0, 0.2);
    }

    input[type="range"] {
      -webkit-appearance: none;
      background: transparent;
      height: 6px;
      border-radius: 3px;
      background: linear-gradient(to right, rgba(255, 215, 0, 0.3), rgba(255, 215, 0, 0.1));
      outline: none;
    }

    input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: linear-gradient(135deg, #ffd700, #ffed4e);
      cursor: pointer;
      box-shadow: 0 0 10px rgba(255, 215, 0, 0.6);
      transition: all 0.2s ease;
    }

    input[type="range"]::-webkit-slider-thumb:hover {
      transform: scale(1.15);
      box-shadow: 0 0 20px rgba(255, 215, 0, 0.8);
    }

    .btn-action {
      background: linear-gradient(135deg, #ffffff, #f0f0f0);
      color: #000;
      border: none;
      padding: 16px;
      border-radius: 10px;
      font-weight: 900;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 0.3s ease;
      letter-spacing: 1px;
      box-shadow: 0 4px 15px rgba(255, 255, 255, 0.1);
      position: relative;
      overflow: hidden;
    }

    .btn-action::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      width: 0;
      height: 0;
      border-radius: 50%;
      background: rgba(255, 215, 0, 0.3);
      transform: translate(-50%, -50%);
      transition: width 0.6s, height 0.6s;
    }

    .btn-action:hover::before {
      width: 300px;
      height: 300px;
    }

    .btn-action:hover { 
      background: linear-gradient(135deg, #ffd700, #ffed4e);
      transform: translateY(-2px);
      box-shadow: 0 6px 25px rgba(255, 215, 0, 0.4);
    }

    .btn-action:active {
      transform: translateY(0);
    }

    .preview-box {
      background: #000;
      padding: 40px;
      display: flex;
      justify-content: center;
      align-items: center;
      position: relative;
    }

    .preview-box::before {
      content: '';
      position: absolute;
      top: 20px;
      left: 20px;
      right: 20px;
      bottom: 20px;
      border: 1px solid rgba(255, 215, 0, 0.1);
      border-radius: 8px;
      pointer-events: none;
    }

    canvas { 
      max-width: 100%; 
      height: auto; 
      border-radius: 8px;
      box-shadow: 
        0 20px 60px rgba(0, 0, 0, 0.8),
        0 0 0 1px rgba(255, 215, 0, 0.2);
      position: relative;
      z-index: 1;
    }

    hr {
      border: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255, 215, 0, 0.3), transparent);
      margin: 15px 0;
    }

    /* Animación de pulso para el botón principal */
    @keyframes pulse {
      0%, 100% { box-shadow: 0 4px 15px rgba(255, 255, 255, 0.1); }
      50% { box-shadow: 0 4px 25px rgba(255, 215, 0, 0.3); }
    }

    #run-btn {
      animation: pulse 2s ease-in-out infinite;
    }
  </style>

  <div class="stage-area">
    <div class="app-window">
      <div class="app-bar"><span class="app-title">ANTONOV CORE v2.4</span></div>
      <div class="system-grid">
        <aside class="side-panel">
          <div class="brand"><h1>ANTONOV</h1><p>SISTEMA DE EXCELENCIA</p></div>
          <div class="control-group">
            <label>SITUACIÓN ACTUAL</label>
            <textarea id="in-pregunta" rows="3" placeholder="¿Qué te detiene?"></textarea>
          </div>
          <button id="run-btn" class="btn-action">EJECUTAR SENTENCIA</button>
          <hr>
          <div class="control-group">
            <label>FORMATO</label>
            <select id="in-format">
              <option value="post">CUADRADO (IG FEED)</option>
              <option value="story">VERTICAL (IG STORY)</option>
            </select>
          </div>
          <div class="control-group">
            <label>TAMAÑO TEXTO</label>
            <input type="range" id="in-size" min="40" max="180" value="100">
          </div>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
            <button id="share-btn" class="btn-action" style="background: linear-gradient(135deg, #25D366, #20BA5A); color: white; font-size: 0.65rem;">COMPARTIR</button>
            <button id="ig-btn" class="btn-action" style="background: linear-gradient(45deg, #f09433, #dc2743, #bc1888); color: white; font-size: 0.65rem;">IG STORY</button>
          </div>
          <button id="dl-btn" style="background: linear-gradient(135deg, #1a1a1a, #0d0d0d); border: 1px solid rgba(255, 215, 0, 0.3); color: #888;" class="btn-action">DESCARGAR PNG</button>
        </aside>

        <main class="preview-box">
          <canvas id="main-canvas"></canvas>
          <input type="hidden" id="hidden-res">
        </main>
      </div>
    </div>
  </div>
  <article class="articulo-antonov">
  <h2>ANTONOV: EL ESPEJO DE LOS LÍDERES</h2>
  
  <p>El desarrollo personal se ha vuelto "suave". Nos hemos acostumbrado a los mensajes que nos dicen que todo está bien, mientras nuestros resultados dicen lo contrario. Por eso nació <strong>Antonov</strong>.</p>

  <p>Antonov no es una herramienta de adivinación. No le interesan las estrellas, ni el azar, ni los horóscopos. Es una <strong>Conciencia Artificial de Choque</strong> diseñada para una sola cosa: sacarte de la zona de confort a través de la verdad brutal.</p>

  <h3>EL PROTOCOLO ES SIMPLE:</h3>
  <ul>
    <li><strong>Sé honesto:</strong> La máquina detecta la falsedad.</li>
    <li><strong>Sé directo:</strong> No busques excusas, describe tu realidad.</li>
    <li><strong>Ejecuta:</strong> Una sentencia sin acción es solo ruido.</li>
  </ul>

  <p class="final-quote">"Aquí no venimos a soñar, venimos a despertar."</p>
</article>

<style>
  .articulo-antonov {
    max-width: 800px; /* Lo hacemos más angosto que la herramienta para que parezca un post */
    margin: 4rem auto; /* Le damos mucho espacio arriba (4rem) para que no se pegue */
    padding: 2rem;
    color: #ccc;
    line-height: 1.8;
    font-family: 'Inter', sans-serif;
    border-top: 1px solid #222; /* Una línea sutil para separar */
  }

  .articulo-antonov h2 {
    font-family: 'Bebas Neue', cursive;
    color: #ffd700;
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .articulo-antonov h3 {
    color: #fff;
    margin-top: 2rem;
    font-size: 1.2rem;
  }

  .articulo-antonov ul {
    list-style: none;
    padding: 0;
  }

  .articulo-antonov li {
    margin-bottom: 1rem;
    border-left: 3px solid #ffd700;
    padding-left: 1rem;
  }

  .final-quote {
    font-style: italic;
    text-align: center;
    margin-top: 3rem;
    color: #fff;
    font-weight: bold;
  }
</style>

 <script is:inline>
  function startSystem() {
    const canvas = document.getElementById('main-canvas');
    const ctx = canvas.getContext('2d');
    
    const ui = {
      q: document.getElementById('in-pregunta'),
      r: document.getElementById('hidden-res'),
      fmt: document.getElementById('in-format'),
      sz: document.getElementById('in-size'),
      btn: document.getElementById('run-btn'),
      dl: document.getElementById('dl-btn'),
      sh: document.getElementById('share-btn'),
      ig: document.getElementById('ig-btn')
    };

    function drawWrappedText(context, text, x, y, maxWidth, lineHeight, centerV) {
      const words = text.split(' ');
      let lines = [];
      let currentLine = '';
      for (let n = 0; n < words.length; n++) {
        let testLine = currentLine + words[n] + ' ';
        if (context.measureText(testLine).width > maxWidth && n > 0) {
          lines.push(currentLine);
          currentLine = words[n] + ' ';
        } else { currentLine = testLine; }
      }
      lines.push(currentLine);
      
      let startY = centerV ? y - ((lines.length - 1) * lineHeight) / 2 : y;
      
      lines.forEach(line => {
        context.fillText(line.trim(), x, startY);
        startY += lineHeight;
      });
    }

    const render = () => {
      const isStory = ui.fmt.value === 'story';
      const w = 1080; const h = isStory ? 1920 : 1080;
      canvas.width = w; canvas.height = h;
      
      // Fondo con gradiente más sofisticado
      const gradient = ctx.createLinearGradient(0, 0, 0, h);
      gradient.addColorStop(0, '#000000');
      gradient.addColorStop(0.5, '#0a0a0a');
      gradient.addColorStop(1, '#000000');
      ctx.fillStyle = gradient;
      ctx.fillRect(0, 0, w, h);

      // Efecto de viñeta sutil
      const vignette = ctx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w*0.7);
      vignette.addColorStop(0, 'rgba(0,0,0,0)');
      vignette.addColorStop(1, 'rgba(0,0,0,0.5)');
      ctx.fillStyle = vignette;
      ctx.fillRect(0, 0, w, h);

      // 1. TEXTO DE LA PREGUNTA (ARRIBA) con sombra dorada
      if(ui.q.value) {
        ctx.font = "italic 600 30px 'Inter'";
        ctx.fillStyle = "rgba(255,255,255,0.35)";
        ctx.textAlign = "center";
        ctx.shadowColor = 'rgba(255, 215, 0, 0.3)';
        ctx.shadowBlur = 20;
        drawWrappedText(ctx, ui.q.value.toUpperCase(), w/2, 120, w*0.8, 45, false);
        ctx.shadowBlur = 0;
      }

      // 2. SENTENCIA PRINCIPAL (CENTRO) con efecto de brillo
      const text = (ui.r.value || "ESPERANDO SENTENCIA...").toUpperCase();
      let fSize = parseInt(ui.sz.value); // Usamos 'let' para poder ajustarlo
      
      // AUTO-AJUSTE: Si la frase es muy larga (más de 80 letras), bajamos el tamaño
      if (text.length > 80) fSize = fSize * 0.75;
      if (text.length > 130) fSize = fSize * 0.6;

      ctx.font = `900 ${fSize}px 'Bebas Neue'`;
      
      // Sombra dorada (El brillo de Antonov)
      ctx.shadowColor = 'rgba(255, 215, 0, 0.6)'; // Subí un pelo la opacidad a 0.6
      ctx.shadowBlur = 25;
      ctx.fillStyle = "#fff";
      ctx.textAlign = "center";
      
      // ESPACIADO DE LETRAS: Para que el brillo no pegue las letras
      ctx.letterSpacing = "2px"; 
      
      // INTERLINEADO CON AIRE: 1.4 para que respire entre líneas
      const interlineadoPro = fSize * 1.4; 
      
      // DIBUJO: Usamos 0.8 del ancho para dejar margen a los lados
      drawWrappedText(ctx, text, w/2, h/2, w * 0.8, interlineadoPro, true);
      
      // RESET DE EFECTOS: Para que no afecte a la marca de abajo
      ctx.shadowBlur = 0;
      ctx.letterSpacing = "0px";

      // 3. MARCA (ABAJO) con efecto premium
      ctx.font = "700 24px 'Inter'";
      
      // Gradiente dorado para la marca
      const brandGradient = ctx.createLinearGradient(0, h - 80, w, h - 80);
      brandGradient.addColorStop(0, '#ffd700');
      brandGradient.addColorStop(0.5, '#ffed4e');
      brandGradient.addColorStop(1, '#ffd700');
      ctx.fillStyle = brandGradient;
      
      ctx.shadowColor = 'rgba(255, 215, 0, 0.6)';
      ctx.shadowBlur = 15;
      ctx.fillText("EL UNIVERSO DE LA MENTE", w/2, h - 80);
      ctx.shadowBlur = 0;
    };

    // --- Lógica de Botones ---
    ui.btn.onclick = async () => {
      if(!ui.q.value) return alert("Escribe algo, líder.");
      ui.btn.innerText = "PROCESANDO...";
      try {
        const res = await fetch('https://mis-frases.poderparatriunfar.workers.dev/', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({ prompt: `Eres Antonov (Estilo Miguel Ángel Cornejo). Contexto: "${ui.q.value}". Responde con 2 FRASES CORTAS Y MATONAS en MAYÚSCULAS. Sé berraco y directo.`})
        });
        const data = await res.json();
       ui.r.value = data.text.replace(/\*\*/g, ''); // Limpia los asteriscos
        render();
      } catch(e) { alert("Error en el núcleo."); }
      finally { ui.btn.innerText = "EJECUTAR SENTENCIA"; }
    };

    ui.dl.onclick = () => {
      const link = document.createElement('a');
      link.download = 'SENTENCIA_ANTONOV.png';
      link.href = canvas.toDataURL();
      link.click();
    };

    ui.sh.onclick = async () => {
      const blob = await (await fetch(canvas.toDataURL())).blob();
      const file = new File([blob], 'sentencia.png', {type: 'image/png'});
      if(navigator.share) await navigator.share({ files: [file] });
      else alert("Descarga la imagen, líder.");
    };

    ui.ig.onclick = () => ui.dl.click();
    ui.sz.oninput = render;
    ui.fmt.onchange = render;
    render();
  }

  document.addEventListener('astro:page-load', startSystem);
  startSystem();
</script>
</Layout>