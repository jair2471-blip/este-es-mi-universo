---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'ANTONOV PRO | Elite Mindset',
  description: 'La conciencia artificial de los líderes.',
};
---

<Layout metadata={metadata}>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;700;900&family=Space+Grotesk:wght@700&display=swap');

    /* Fondo de escritorio para que parezca una App flotante */
    body {
      background: #080808;
      background-image: 
        radial-gradient(at 0% 0%, rgba(255, 215, 0, 0.05) 0px, transparent 50%),
        radial-gradient(at 100% 100%, rgba(255, 255, 255, 0.02) 0px, transparent 50%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      font-family: 'Inter', sans-serif;
    }

    /* El contenedor de la "Aplicación" */
    .app-window {
      width: 100%;
      max-width: 1100px; /* Evita que ocupe toda la pantalla en PC */
      background: rgba(15, 15, 15, 0.8);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 50px 100px -20px rgba(0, 0, 0, 0.7);
      display: flex;
      flex-direction: column;
    }

    /* Barra superior tipo Mac/Windows */
    .app-bar {
      padding: 15px 25px;
      background: rgba(255, 255, 255, 0.03);
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .dots { display: flex; gap: 8px; }
    .dot { width: 12px; height: 12px; border-radius: 50%; background: #333; }
    .dot.gold { background: #ffd700; box-shadow: 0 0 10px rgba(255, 215, 0, 0.3); }

    .app-title {
      font-family: 'Space Grotesk', sans-serif;
      color: #fff;
      font-size: 0.8rem;
      letter-spacing: 3px;
      font-weight: 700;
      opacity: 0.6;
    }

    .system-grid {
      display: grid;
      grid-template-columns: 1fr;
      min-height: 600px;
    }

    @media (min-width: 900px) {
      .system-grid { grid-template-columns: 380px 1fr; }
    }

    /* Panel de controles (Izquierda) */
    .side-panel {
      padding: 40px;
      border-right: 1px solid rgba(255, 255, 255, 0.05);
      display: flex;
      flex-direction: column;
      gap: 25px;
    }

    .brand-box { margin-bottom: 10px; }
    .brand-box h1 { font-family: 'Bebas Neue', cursive; font-size: 3.5rem; color: #fff; line-height: 1; margin: 0; }
    .brand-box p { color: #ffd700; font-size: 0.7rem; letter-spacing: 2px; font-weight: 700; }

    .input-group { display: flex; flex-direction: column; gap: 10px; }
    .label { color: #555; font-size: 0.65rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1.5px; }

    textarea, select, input[type="range"] {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      color: #fff;
      padding: 15px;
      font-size: 0.9rem;
      transition: 0.3s;
    }

    textarea:focus { border-color: #ffd700; outline: none; background: rgba(255, 255, 255, 0.05); }

    .btn-fire {
      background: #fff;
      color: #000;
      border: none;
      padding: 18px;
      border-radius: 12px;
      font-weight: 900;
      text-transform: uppercase;
      cursor: pointer;
      transition: 0.3s;
      box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    }
    .btn-fire:hover { background: #ffd700; transform: translateY(-2px); }

    /* Área del Canvas (Derecha) */
    .preview-area {
      background: #000;
      padding: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }

    canvas {
      max-width: 100%;
      max-height: 70vh;
      border-radius: 8px;
      box-shadow: 0 30px 60px rgba(0,0,0,0.5);
    }

    .download-link {
      margin-top: 20px;
      color: rgba(255,255,255,0.3);
      font-size: 0.7rem;
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .download-link:hover { color: #fff; }

    /* Animación de carga */
    .loading-pulse { animation: pulse 1.5s infinite; }
    @keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.4; } 100% { opacity: 1; } }
  </style>

  <div class="app-window">
    <div class="app-bar">
      <div class="dots">
        <div class="dot"></div>
        <div class="dot"></div>
        <div class="dot gold"></div>
      </div>
      <div class="app-title">ANTONOV CORE SYSTEM V2.0</div>
      <div style="width: 50px;"></div>
    </div>

    <div class="system-grid">
      <aside class="side-panel">
        <div class="brand-box">
          <h1>ANTONOV</h1>
          <p>ORÁCULO DE EXCELENCIA</p>
        </div>

        <div class="input-group">
          <span class="label">Entrada de Realidad</span>
          <textarea id="pregunta" placeholder="Escribe tu situación..." rows="3"></textarea>
        </div>

        <button id="btn-run" class="btn-fire">SACUDIR CONCIENCIA</button>

        <div class="input-group">
          <span class="label">Formato & Tamaño</span>
          <select id="format">
            <option value="post">IG POST (1:1)</option>
            <option value="story">IG STORY (9:16)</option>
          </select>
          <input type="range" id="size" min="40" max="150" value="100">
        </div>

        <button id="btn-save" style="background: transparent; border: 1px solid #333; color: #666;" class="btn-fire">DESCARGAR ARTE</button>
      </aside>

      <main class="preview-area">
        <canvas id="canvas"></canvas>
        <textarea id="resp_hidden" style="display: none;"></textarea>
      </main>
    </div>
  </div>

  <script is:inline>
    function boot() {
      const canvas = document.getElementById('canvas');
      const ctx = canvas.getContext('2d');
      const inputs = {
        q: document.getElementById('pregunta'),
        r: document.getElementById('resp_hidden'),
        fmt: document.getElementById('format'),
        sz: document.getElementById('size'),
        btn: document.getElementById('btn-run'),
        dl: document.getElementById('btn-save')
      };

      const draw = () => {
        const isStory = inputs.fmt.value === 'story';
        const w = 1080;
        const h = isStory ? 1920 : 1080;
        canvas.width = w; canvas.height = h;

        // Background
        ctx.fillStyle = '#000';
        ctx.fillRect(0, 0, w, h);

        // Noise
        for(let i=0; i<5000; i++) {
          ctx.fillStyle = `rgba(255,255,255,${Math.random()*0.02})`;
          ctx.fillRect(Math.random()*w, Math.random()*h, 1, 1);
        }

        // Render Pregunta (Top)
        const qVal = inputs.q.value.trim().toUpperCase();
        if(qVal) {
          ctx.font = "600 30px 'Inter'";
          ctx.fillStyle = "rgba(255,255,255,0.3)";
          ctx.textAlign = "center";
          wrapText(ctx, qVal, w/2, 120, w*0.8, 40);
        }

        // Render Respuesta (Center)
        const rVal = (inputs.r.value || "ESPERANDO COMANDO...").toUpperCase();
        const fSize = parseInt(inputs.sz.value);
        ctx.font = `900 ${fSize}px 'Bebas Neue'`;
        ctx.fillStyle = "#fff";
        ctx.textAlign = "center";
        ctx.textBaseline = "middle";
        wrapText(ctx, rVal, w/2, h/2, w*0.85, fSize * 1.05);

        // Branding (Bottom)
        ctx.font = "700 22px 'Inter'";
        ctx.fillStyle = "#ffd700";
        ctx.letterSpacing = "12px";
        ctx.fillText("EL UNIVERSO DE LA MENTE", w/2, h - 100);
      };

      function wrapText(context, text, x, y, maxWidth, lineHeight) {
        const words = text.split(' ');
        let line = '';
        let lines = [];
        for(let n = 0; n < words.length; n++) {
          let testLine = line + words[n] + ' ';
          if (context.measureText(testLine).width > maxWidth && n > 0) {
            lines.push(line);
            line = words[n] + ' ';
          } else { line = testLine; }
        }
        lines.push(line);
        let currentY = y - ((lines.length - 1) * lineHeight) / 2;
        lines.forEach(l => {
          context.fillText(l, x, currentY);
          currentY += lineHeight;
        });
      }

      inputs.btn.onclick = async () => {
        if(!inputs.q.value) return;
        inputs.btn.innerText = "SINTONIZANDO...";
        inputs.btn.classList.add('loading-pulse');
        
        try {
          const res = await fetch('https://mis-frases.poderparatriunfar.workers.dev/', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ prompt: `Eres Antonov (Estilo Miguel Ángel Cornejo). Contexto: "${inputs.q.value}". Responde con 2 FRASES CORTAS Y MATONAS en MAYÚSCULAS. Sé berraco y directo.`})
          });
          const data = await res.json();
          inputs.r.value = data.text;
          draw();
        } catch (e) { alert("Error de sistema."); }
        finally {
          inputs.btn.innerText = "SACUDIR CONCIENCIA";
          inputs.btn.classList.remove('loading-pulse');
        }
      };

      inputs.sz.oninput = draw;
      inputs.fmt.onchange = draw;
      inputs.dl.onclick = () => {
        const link = document.createElement('a');
        link.download = 'ANTONOV-ARTE.png';
        link.href = canvas.toDataURL();
        link.click();
      };

      draw();
    }

    document.addEventListener('astro:page-load', boot);
    boot();
  </script>
</Layout>