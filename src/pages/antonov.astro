---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'ANTONOV V5.0 | Núcleo de Personalidades',
  description: 'Sistema robusto de diseño industrial impulsado por IA.',
};
---

<Layout metadata={metadata}>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;900&family=Space+Mono:wght@400;700&display=swap');

    .antonov-body {
      background-color: #050505;
      color: white;
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      padding: 2rem 1rem;
    }

    .container {
      max-width: 1400px;
      margin: 0 auto;
      width: 100%;
    }

    .header-section {
      text-align: center;
      margin-bottom: 40px;
    }

    .header-title {
      font-size: clamp(2rem, 5vw, 4rem);
      font-weight: 900;
      color: #22c55e;
      font-style: italic;
      text-transform: uppercase;
      line-height: 1;
      margin-bottom: 8px;
    }

    .header-subtitle {
      color: #ea580c;
      font-weight: bold;
      letter-spacing: 2px;
      font-size: 0.7rem;
      text-transform: uppercase;
    }

    .voice-name-display {
      color: #fff;
      font-weight: 900;
    }

    .system-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 30px;
    }

    @media (min-width: 1024px) {
      .system-grid {
        grid-template-columns: 380px 1fr;
      }
    }

    .antonov-panel {
      background: #000;
      border: 2px solid #222;
      padding: 25px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .control-group {
      margin-bottom: 10px;
    }

    .label-control {
      color: #666;
      font-weight: bold;
      font-size: 0.7rem;
      display: block;
      margin-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .label-voice {
      color: #ea580c;
    }

    .antonov-input {
      width: 100%;
      background: #111;
      border: 1px solid #333;
      color: white;
      padding: 12px;
      font-family: 'Space Mono', monospace;
      font-size: 0.9rem;
      outline: none;
    }

    .antonov-input:focus {
      border-color: #ea580c;
    }

    .voice-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 10px;
    }

    .v-btn {
      background: #111;
      border: 2px solid #222;
      padding: 10px;
      cursor: pointer;
      font-size: 1.5rem;
      filter: grayscale(1);
      transition: 0.3s;
      display: flex;
      align-items: center;
      justify-content: center;
      aspect-ratio: 1;
    }

    .v-btn.active {
      border-color: #ea580c;
      background: #1a1a1a;
      filter: grayscale(0);
      transform: scale(1.1);
      box-shadow: 0 0 20px rgba(234, 88, 12, 0.2);
    }

    .antonov-btn {
      width: 100%;
      padding: 16px;
      font-weight: 900;
      text-transform: uppercase;
      cursor: pointer;
      border: none;
      transition: 0.2s;
      font-size: 0.8rem;
      letter-spacing: 2px;
    }

    .btn-gemini {
      background: #27272a;
      color: #ea580c;
    }

    .btn-gemini:hover:not(:disabled) {
      background: #3f3f46;
    }

    .btn-random {
      background: #18181b;
      color: #a1a1aa;
      margin-top: 10px;
    }

    .btn-download {
      background: #ea580c;
      color: black;
      margin-top: 20px;
    }

    .btn-download:hover {
      background: #16a34a;
    }

    .antonov-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .canvas-container {
      background: #0a0a0a;
      border: 2px solid #222;
      padding: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 500px;
      overflow: hidden;
    }

    canvas {
      max-width: 100%;
      height: auto !important;
      border: 1px solid #333;
      box-shadow: 0 0 50px rgba(0, 0, 0, 0.5);
    }

    .slider-container {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .slider-container input {
      flex: 1;
      accent-color: #ea580c;
    }

    .size-display {
      font-family: 'Space Mono', monospace;
      color: #ea580c;
      font-weight: bold;
      min-width: 50px;
    }

    .divider {
      border-top: 1px solid #222;
      padding-top: 20px;
      margin-top: 10px;
    }
  </style>

  <section class="antonov-body">
    <div class="container">
      <div class="header-section">
        <h1 class="header-title">ANTONOV V5.0</h1>
        <p class="header-subtitle">
          SISTEMA MULTI-NÚCLEO // <span id="current-voice-name" class="voice-name-display">SAPO HONESTO</span>
        </p>
      </div>

      <div class="system-grid">
        <aside class="antonov-panel">
          <div class="control-group">
            <label class="label-control label-voice">◢ SELECCIONAR NÚCLEO:</label>
            <div class="voice-grid">
              <button class="v-btn active" data-voice="sapo" title="Sapo Honesto">🐸</button>
              <button class="v-btn" data-voice="coach" title="Coach Sin Azúcar">🥊</button>
              <button class="v-btn" data-voice="zen" title="Zen Callejero">🕶️</button>
              <button class="v-btn" data-voice="bufon" title="Bufón Filosófico">🃏</button>
              <button class="v-btn" data-voice="abuela" title="Abuela Sabia">👵</button>
            </div>
          </div>

          <div class="control-group">
            <label class="label-control">▸ Texto del Núcleo:</label>
            <textarea id="quote" rows="4" class="antonov-input" placeholder="SISTEMA LISTO..."></textarea>
          </div>

          <div class="control-group">
            <button id="btn-gemini" class="antonov-btn btn-gemini">
              <span id="btn-text">🤖 GENERAR CON GEMINI</span>
            </button>
            <button id="btn-random" class="antonov-btn btn-random">🎲 FRASE ALEATORIA</button>
          </div>

          <div class="control-group divider">
            <label class="label-control">▸ Tamaño de Fuente:</label>
            <div class="slider-container">
              <input type="range" id="fontSizeSlider" min="20" max="300" value="80" />
              <span id="sizeVal" class="size-display">80px</span>
            </div>
          </div>

          <div class="control-group">
            <label class="label-control">▸ Formato y Glitch:</label>
            <select id="format" class="antonov-input" style="margin-bottom: 10px">
              <option value="post">CUADRADO (1080x1080)</option>
              <option value="story">STORY (1080x1920)</option>
              <option value="banner">BANNER (1920x1080)</option>
            </select>
            <select id="intensity" class="antonov-input">
              <option value="0.5">GLITCH: BAJO</option>
              <option value="1.0" selected>GLITCH: ALTO</option>
              <option value="1.5">GLITCH: EXTREMO</option>
            </select>
          </div>

          <button id="btn-download" class="antonov-btn btn-download">⬇ DESCARGAR IMAGEN</button>
        </aside>

        <section class="canvas-container">
          <canvas id="canvas"></canvas>
        </section>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      const runAntonov = () => {
        const canvas = document.getElementById('canvas');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');

        const el = {
          format: document.getElementById('format'),
          quote: document.getElementById('quote'),
          intensity: document.getElementById('intensity'),
          slider: document.getElementById('fontSizeSlider'),
          sizeVal: document.getElementById('sizeVal'),
          btnGemini: document.getElementById('btn-gemini'),
          btnText: document.getElementById('btn-text'),
          btnRandom: document.getElementById('btn-random'),
          btnDownload: document.getElementById('btn-download'),
          voiceButtons: document.querySelectorAll('[data-voice]'),
          voiceName: document.getElementById('current-voice-name'),
        };

        // AQUÍ ESTABA EL ERROR: RECONSTRUI LAS PERSONALIDADES QUE FALTABAN
        const personalidades = {
          sapo: {
            nombre: 'SAPO HONESTO',
            color: '#22c55e',
            prompt: 'Eres un sapo filósofo de barrio. Tu estilo es crudo, directo y callejero. Usas jerga colombiana/latina. Das consejos de vida brutales. Genera UNA frase corta, impactante, MAYÚSCULAS.',
            frases: ['LA VIDA ES DURA PERO MÁS DURO ES EL CEMENTO', 'SI NO SUMA QUE NO ESTORBE', 'O CORRES O TE ENCARAMAS', 'PAPAYA PUESTA PAPAYA PARTIDA']
          },
          coach: {
            nombre: 'COACH SIN AZÚCAR',
            color: '#ef4444',
            prompt: 'Eres un entrenador militar agresivo. Odias las excusas. Gritas verdades incómodas. Genera UNA frase corta, agresiva, MAYÚSCULAS.',
            frases: ['EL DOLOR ES TU AMIGO', 'TU PEREZA ME DA ASCO', 'LEVÁNTATE Y SUFRE', 'LAS EXCUSAS NO QUEMAN CALORÍAS']
          },
          zen: {
            nombre: 'ZEN CALLEJERO',
            color: '#a855f7',
            prompt: 'Eres un monje budista urbano. Mezclas espiritualidad con realidad de la calle. Genera UNA frase profunda, mística pero barrial en MAYÚSCULAS.',
            frases: ['RESPIRA Y NO MATES A NADIE', 'EL KARMA TIENE GPS', 'ESTO TAMBIÉN PASA', 'LA CALMA ES PODER']
          },
          bufon: {
            nombre: 'BUFÓN FILOSÓFICO',
            color: '#eab308',
            prompt:
              'Eres un crítico social sarcástico latino que usa humor negro para exponer hipocresías. Tu estilo es mordaz, irónico. Genera UNA frase irónica de máximo 6 palabras sobre consumismo o falsedad social. Solo la frase en MAYÚSCULAS.',
            frases: [
              'EL ESCLAVO MEJOR VESTIDO',
              'PAYASO CON IPHONE',
              'REÍR ES MÁS BARATO QUE TERAPIA',
              'TODOS SOMOS CIRCO PERO SIN CARPA',
              'FELIZ CON LIKES VACÍO POR DENTRO',
            ],
          },
          abuela: {
            nombre: 'ABUELA SABIA',
            color: '#3b82f6',
            prompt:
              'Eres una abuela latina con décadas de experiencia. Das consejos simples pero poderosos. Genera UN consejo de máximo 6 palabras. Solo la frase en MAYÚSCULAS.',
            frases: [
              'POCO A POCO SE ANDA LEJOS',
              'LA PLATA ES PAPEL',
              'LO QUE FÁCIL LLEGA FÁCIL SE VA',
              'LA PACIENCIA TODO LO ALCANZA',
              'MÁS VALE TARDE QUE NUNCA',
            ],
          },
        };

        let selectedVoice = 'sapo';

        const render = () => {
          const format = el.format.value;
          const text = (el.quote.value || 'SISTEMA LISTO').toUpperCase();
          const intensity = parseFloat(el.intensity.value || 1.0);
          const fontSize = parseInt(el.slider.value || 80);
          const per = personalidades[selectedVoice];
          if (el.sizeVal) el.sizeVal.innerText = fontSize + 'px';

          let w = 1080,
            h = 1080;
          if (format === 'story') {
            w = 1080;
            h = 1920;
          }
          if (format === 'banner') {
            w = 1920;
            h = 1080;
          }
          canvas.width = w;
          canvas.height = h;

          ctx.fillStyle = '#000';
          ctx.fillRect(0, 0, w, h);
          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          ctx.font = `900 ${fontSize}px monospace`;

          const words = text.split(' ');
          let lines = [],
            currentLine = words[0];
          for (let i = 1; i < words.length; i++) {
            if (ctx.measureText(currentLine + ' ' + words[i]).width < w * 0.85) {
              currentLine += ' ' + words[i];
            } else {
              lines.push(currentLine);
              currentLine = words[i];
            }
          }
          lines.push(currentLine);

          const lineHeight = fontSize * 1.15;
          const totalHeight = lines.length * lineHeight;
          const startY = h / 2 - totalHeight / 2 + fontSize / 2;

          lines.forEach((line, i) => {
            const y = startY + i * lineHeight;
            const offset = 8 * intensity;
            ctx.fillStyle = 'rgba(255, 0, 0, 0.7)';
            ctx.fillText(line, w / 2 + offset, y);
            ctx.fillStyle = 'rgba(0, 255, 255, 0.7)';
            ctx.fillText(line, w / 2 - offset, y);
            ctx.fillStyle = '#fff';
            ctx.fillText(line, w / 2, y);
          });

          ctx.strokeStyle = per.color;
          ctx.lineWidth = 12;
          ctx.strokeRect(25, 25, w - 50, h - 50);
          ctx.fillStyle = per.color;
          ctx.font = `bold ${w * 0.025}px monospace`;
          ctx.fillText(`>>> ${per.nombre} <<<`, w / 2, h - 60);
        };

        const callGemini = async () => {
          const per = personalidades[selectedVoice];
          el.btnGemini.disabled = true;
          el.btnText.textContent = '⏳ GENERANDO...';
          try {
            const response = await fetch('https://mis-frases.poderparatriunfar.workers.dev/', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ prompt: per.prompt }),
            });
            const data = await response.json();
            if (!response.ok) throw new Error(data.error || `Error ${response.status}`);
            el.quote.value = data.text.toUpperCase();
            render();
          } catch (error) {
            console.error('Error:', error);
            alert(`❌ Error: ${error.message}`);
          } finally {
            el.btnGemini.disabled = false;
            el.btnText.textContent = '🤖 GENERAR CON GEMINI';
          }
        };

        el.voiceButtons.forEach((btn) => {
          btn.onclick = (e) => {
            e.preventDefault();
            el.voiceButtons.forEach((b) => b.classList.remove('active'));
            btn.classList.add('active');
            selectedVoice = btn.getAttribute('data-voice');
            if (el.voiceName) el.voiceName.innerText = personalidades[selectedVoice].nombre;
            render();
          };
        });

        [el.format, el.intensity, el.slider, el.quote].forEach((input) => {
          if (input) input.oninput = render;
        });
        el.btnGemini.onclick = callGemini;
        el.btnRandom.onclick = () => {
          const frases = personalidades[selectedVoice].frases;
          el.quote.value = frases[Math.floor(Math.random() * frases.length)];
          render();
        };
        el.btnDownload.onclick = () => {
          const link = document.createElement('a');
          link.download = `ANTONOV-${selectedVoice}-${Date.now()}.png`;
          link.href = canvas.toDataURL();
          link.click();
        };
        render();
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', runAntonov);
      } else {
        runAntonov();
      }
    })();
  </script>
</Layout>
