<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const canvas = document.getElementById('canvas');
    if (!canvas) return;

    const ctx = canvas.getContext('2d');

    const el = {
      format: document.getElementById('format'),
      quote: document.getElementById('quote'),
      intensity: document.getElementById('intensity'),
      slider: document.getElementById('fontSizeSlider'),
      sizeVal: document.getElementById('sizeVal'),
      btnGemini: document.getElementById('btn-gemini'),
      btnText: document.getElementById('btn-text'),
      btnRandom: document.getElementById('btn-random'),
      btnDownload: document.getElementById('btn-download'),
      voiceButtons: document.querySelectorAll('[data-voice]'),
      voiceName: document.getElementById('current-voice-name'),
    };

    const personalidades = {
      sapo: {
        nombre: 'ANTONOV // VERDAD',
        color: '#22c55e',
        basePrompt:
          'Dicta una sentencia brutal y directa sobre realidad, dinero o responsabilidad personal.',
      },
      coach: {
        nombre: 'ANTONOV // DISCIPLINA',
        color: '#ef4444',
        basePrompt:
          'Exige acción y disciplina. No motives. No consueles. Dicta una ley.',
      },
      zen: {
        nombre: 'ANTONOV // CONCIENCIA',
        color: '#a855f7',
        basePrompt:
          'Revela una verdad profunda sobre control interno, silencio y dominio emocional.',
      },
    };

    let selectedVoice = 'sapo';

    const render = () => {
      const format = el.format.value;
      const text = (el.quote.value || 'SISTEMA LISTO').toUpperCase();
      const intensity = parseFloat(el.intensity.value || 1.0);
      const fontSize = parseInt(el.slider.value || 80);
      const per = personalidades[selectedVoice];

      el.sizeVal.innerText = fontSize + 'px';

      let w = 1080,
        h = 1080;
      if (format === 'story') h = 1920;
      if (format === 'banner') w = 1920;

      canvas.width = w;
      canvas.height = h;

      ctx.fillStyle = '#000';
      ctx.fillRect(0, 0, w, h);
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.font = `900 ${fontSize}px monospace`;

      const words = text.split(' ');
      let lines = [];
      let current = words[0];

      for (let i = 1; i < words.length; i++) {
        if (ctx.measureText(current + ' ' + words[i]).width < w * 0.85) {
          current += ' ' + words[i];
        } else {
          lines.push(current);
          current = words[i];
        }
      }
      lines.push(current);

      const lh = fontSize * 1.15;
      const startY = h / 2 - (lines.length * lh) / 2 + fontSize / 2;

      lines.forEach((line, i) => {
        const y = startY + i * lh;
        const off = 8 * intensity;

        ctx.fillStyle = 'rgba(255,0,0,0.6)';
        ctx.fillText(line, w / 2 + off, y);
        ctx.fillStyle = 'rgba(0,255,255,0.6)';
        ctx.fillText(line, w / 2 - off, y);
        ctx.fillStyle = '#fff';
        ctx.fillText(line, w / 2, y);
      });

      ctx.strokeStyle = per.color;
      ctx.lineWidth = 12;
      ctx.strokeRect(25, 25, w - 50, h - 50);

      ctx.fillStyle = per.color;
      ctx.font = `bold ${w * 0.025}px monospace`;
      ctx.fillText(per.nombre, w / 2, h - 60);
    };

    const callGemini = async () => {
      const per = personalidades[selectedVoice];
      const keywords = el.quote.value.trim().toUpperCase();

      const prompt = `
${per.basePrompt}
PALABRAS CLAVE DEL CONFLICTO:
${keywords || 'NO PROPORCIONADAS'}

REGLAS:
- 10 a 14 palabras
- MAYÚSCULAS
- SIN CLICHÉS
- VERDAD + CONSECUENCIA
- UNA SOLA FRASE
`;

      el.btnGemini.disabled = true;
      el.btnText.textContent = '⏳ DICTANDO SENTENCIA...';

      try {
        const res = await fetch('https://mis-frases.poderparatriunfar.workers.dev/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ prompt }),
        });

        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'ERROR');

        el.quote.value = data.text.toUpperCase();
        setTimeout(render, 300);
      } catch (e) {
        alert('ERROR DE NÚCLEO');
        console.error(e);
      } finally {
        el.btnGemini.disabled = false;
        el.btnText.textContent = '🤖 GENERAR CON GEMINI';
      }
    };

    el.voiceButtons.forEach((btn) => {
      btn.onclick = (e) => {
        e.preventDefault();
        el.voiceButtons.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        selectedVoice = btn.dataset.voice;
        el.voiceName.innerText = personalidades[selectedVoice].nombre;
        render();
      };
    });

    [el.format, el.intensity, el.slider, el.quote].forEach((i) => {
      if (i) i.oninput = render;
    });

    el.btnGemini.onclick = callGemini;

    el.btnDownload.onclick = () => {
      const a = document.createElement('a');
      a.download = `ANTONOV-${selectedVoice}-${Date.now()}.png`;
      a.href = canvas.toDataURL();
      a.click();
    };

    render();
  });
</script>
