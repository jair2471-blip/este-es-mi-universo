---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'ANTONOV | Oráculo de la Mente',
  description: 'La conciencia artificial que te sacude con la verdad de la excelencia.',
};
---

<Layout metadata={metadata}>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;700;900&family=Space+Grotesk:wght@700&family=JetBrains+Mono:wght@700&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: radial-gradient(circle at 50% 0%, #121212 0%, #000 100%);
      min-height: 100vh;
      overflow-x: hidden;
    }

    .oraculo-wrapper {
      max-width: 1400px;
      margin: 0 auto;
      padding: 2rem 1rem;
      min-height: 100vh;
      display: flex;
      align-items: center;
    }

    .oraculo-container {
      background: #000;
      border: 1px solid #1a1a1a;
      border-radius: 16px;
      box-shadow: 0 40px 100px rgba(0,0,0,0.8);
      width: 100%;
      overflow: hidden;
      position: relative;
    }

    .header-section {
      text-align: center;
      padding: 4rem 2rem;
      background: linear-gradient(180deg, rgba(255,255,255,0.03) 0%, transparent 100%);
      border-bottom: 1px solid #111;
    }

    .header-title {
      font-size: clamp(3rem, 8vw, 6rem);
      font-weight: 900;
      color: #fff;
      text-transform: uppercase;
      line-height: 0.8;
      letter-spacing: -4px;
      font-family: 'Space Grotesk', sans-serif;
      text-shadow: 0 0 30px rgba(255,255,255,0.1);
    }

    .header-subtitle {
      color: #ffd700;
      font-weight: 700;
      letter-spacing: 5px;
      font-size: 0.8rem;
      text-transform: uppercase;
      margin-top: 1rem;
    }

    .system-grid {
      display: grid;
      grid-template-columns: 1fr;
    }

    @media (min-width: 1024px) {
      .system-grid { grid-template-columns: 400px 1fr; }
    }

    .oraculo-panel {
      background: #050505;
      border-right: 1px solid #111;
      padding: 2.5rem;
    }

    .label-control {
      color: #555;
      font-weight: 800;
      font-size: 0.7rem;
      margin-bottom: 0.8rem;
      display: block;
      text-transform: uppercase;
      letter-spacing: 2px;
    }

    .oraculo-input {
      width: 100%;
      background: #0f0f0f;
      border: 1px solid #222;
      color: #fff;
      padding: 1.2rem;
      border-radius: 8px;
      font-family: 'Inter', sans-serif;
      margin-bottom: 1.5rem;
      transition: all 0.3s;
    }

    .btn-main {
      width: 100%;
      padding: 1.2rem;
      border-radius: 8px;
      font-weight: 900;
      text-transform: uppercase;
      cursor: pointer;
      border: none;
      letter-spacing: 1px;
      transition: 0.3s;
    }

    .btn-consultar { background: #fff; color: #000; }
    .btn-consultar:hover { background: #ffd700; transform: scale(1.02); }

    .canvas-container {
      background: #000;
      padding: 4rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 700px;
    }

    #canvas {
      max-width: 100%;
      height: auto;
      border: 1px solid #1a1a1a;
    }

    .shake { animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both; }
    @keyframes shake {
      10%, 90% { transform: translate3d(-1px, 0, 0); }
      20%, 80% { transform: translate3d(2px, 0, 0); }
      30%, 50%, 70% { transform: translate3d(-4px, 0, 0); }
      40%, 60% { transform: translate3d(4px, 0, 0); }
    }
  </style>

  <div class="oraculo-wrapper">
    <div class="oraculo-container">
      <header class="header-section">
        <h1 class="header-title">ANTONOV</h1>
        <p class="header-subtitle">Conciencia Artificial de Excelencia</p>
      </header>

      <div class="system-grid">
        <aside class="oraculo-panel">
          <label class="label-control">Tu Realidad Actual</label>
          <textarea id="pregunta" class="oraculo-input" placeholder="Escribe tu queja o duda aquí..."></textarea>
          
          <button id="btn-consultar" class="btn-main btn-consultar">👁️ SACUDIR MI CONCIENCIA</button>
          
          <div style="margin-top: 2rem;">
            <label class="label-control">Personalizar Imagen</label>
            <select id="format" class="oraculo-input">
              <option value="post">INSTAGRAM POST</option>
              <option value="story">INSTAGRAM STORY</option>
            </select>
            <input type="range" id="fontSizeSlider" min="40" max="150" value="100" class="oraculo-input" />
          </div>

          <button id="btn-download" class="btn-main" style="background:#111; color:#fff; border: 1px solid #333;">⬇ DESCARGAR SENTENCIA</button>
        </aside>

        <section class="canvas-container" id="canvas-area">
          <canvas id="canvas"></canvas>
          <textarea id="respuesta" style="display: none;"></textarea>
        </section>
      </div>
    </div>
  </div>

  <script is:inline>
    function initOraculo() {
      const canvas = document.getElementById('canvas');
      const ctx = canvas.getContext('2d');
      const el = {
        pregunta: document.getElementById('pregunta'),
        respuesta: document.getElementById('respuesta'),
        format: document.getElementById('format'),
        slider: document.getElementById('fontSizeSlider'),
        btn: document.getElementById('btn-consultar'),
        download: document.getElementById('btn-download'),
        area: document.getElementById('canvas-area')
      };

      const render = () => {
        const isStory = el.format.value === 'story';
        const w = 1080;
        const h = isStory ? 1920 : 1080;
        canvas.width = w; canvas.height = h;

        // Fondo
        ctx.fillStyle = '#000';
        ctx.fillRect(0, 0, w, h);

        // Ruido
        for (let i = 0; i < 8000; i++) {
          ctx.fillStyle = `rgba(255,255,255,${Math.random() * 0.015})`;
          ctx.fillRect(Math.random() * w, Math.random() * h, 1, 1);
        }

        // 🔥 PINTE LA PREGUNTA ARRIBA (CONTEXTO) 🔥
        const preguntaTexto = el.pregunta.value.trim();
        if (preguntaTexto) {
          const qSize = Math.max(w * 0.03, 28);
          ctx.font = `italic 600 ${qSize}px 'Inter'`;
          ctx.fillStyle = 'rgba(255, 255, 255, 0.4)';
          ctx.textAlign = 'center';
          
          const wordsQ = preguntaTexto.toUpperCase().split(' ');
          let linesQ = [], lineQ = '';
          wordsQ.forEach(word => {
            if (ctx.measureText(lineQ + word).width < w * 0.8) lineQ += word + ' ';
            else { linesQ.push(lineQ); lineQ = word + ' '; }
          });
          linesQ.push(lineQ);
          
          linesQ.forEach((l, i) => {
            ctx.fillText(l, w/2, 100 + (i * qSize * 1.3));
          });
        }

        // Sentencia
        const text = (el.respuesta.value || "HAZ UNA PREGUNTA PARA DESPERTAR").toUpperCase();
        const fontSize = parseInt(el.slider.value);
        ctx.font = `900 ${fontSize}px 'Bebas Neue'`;
        ctx.fillStyle = '#fff';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';

        const words = text.split(' ');
        let lines = [], line = '';
        words.forEach(wrd => {
          if (ctx.measureText(line + wrd).width < w * 0.85) line += wrd + ' ';
          else { lines.push(line); line = wrd + ' '; }
        });
        lines.push(line);

        const totalH = lines.length * (fontSize * 1.05);
        const startY = h/2 - totalH/2 + fontSize/2;

        lines.forEach((l, i) => {
          ctx.fillText(l, w/2, startY + (i * fontSize * 1.05));
        });

        // Branding
        ctx.font = `700 25px 'Inter'`;
        ctx.fillStyle = '#ffd700';
        ctx.letterSpacing = '10px';
        ctx.fillText('EL UNIVERSO DE LA MENTE', w/2, h - 80);
      };

      el.btn.onclick = async () => {
        if (!el.pregunta.value) return alert("¡No seas mediocre, pregunta algo!");
        el.btn.innerText = "PROCESANDO REALIDAD...";
        try {
          const res = await fetch('https://mis-frases.poderparatriunfar.workers.dev/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ prompt: `Actúa como Antonov (Estilo Miguel Ángel Cornejo). Contexto: "${el.pregunta.value}". Responde SOLO 2 FRASES EN MAYÚSCULAS. Primera frase: Diagnóstico crudo. Segunda frase: Acción inmediata.` })
          });
          const data = await res.json();
          el.respuesta.value = data.text;
          el.area.classList.add('shake');
          setTimeout(() => el.area.classList.remove('shake'), 500);
          render();
        } catch (e) { alert("Error cuántico."); }
        finally { el.btn.innerText = "👁️ SACUDIR MI CONCIENCIA"; }
      };

      el.slider.oninput = render;
      el.format.onchange = render;
      el.download.onclick = () => {
        const a = document.createElement('a');
        a.download = 'ANTONOV-SENTENCIA.png';
        a.href = canvas.toDataURL();
        a.click();
      };
      render();
    }
    document.addEventListener('astro:page-load', initOraculo);
    initOraculo();
  </script>
</Layout>