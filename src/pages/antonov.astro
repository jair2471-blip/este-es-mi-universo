---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'ANTONOV V5.0 | Núcleo de Personalidades',
  description: 'Sistema robusto de diseño industrial impulsado por IA.',
};
---

<Layout metadata={metadata}>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;900&family=Space+Mono:wght@400;700&display=swap');

    .antonov-wrapper {
      max-width: 1400px;
      margin: 3rem auto;
      padding: 0 1rem;
    }

    .antonov-container {
      background: #050505;
      border: 2px solid #222;
      border-radius: 8px;
      padding: 2.5rem;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    }

    .antonov-body {
      color: white;
      font-family: 'Inter', sans-serif;
    }

    .header-section {
      text-align: center;
      margin-bottom: 2.5rem;
    }

    .header-title {
      font-size: clamp(2.5rem, 6vw, 4rem);
      font-weight: 900;
      color: #22c55e;
      font-style: italic;
      text-transform: uppercase;
      line-height: 1;
      margin-bottom: 0.5rem;
      text-shadow: 0 0 20px rgba(34, 197, 94, 0.3);
    }

    .header-subtitle {
      color: #ea580c;
      font-weight: bold;
      letter-spacing: 2px;
      font-size: 0.7rem;
      text-transform: uppercase;
    }

    .voice-name-display {
      color: #fff;
      font-weight: 900;
    }

    .system-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    @media (min-width: 1024px) {
      .system-grid {
        grid-template-columns: 340px 1fr;
      }
    }

    .antonov-panel {
      background: #000;
      border: 2px solid #222;
      padding: 1.5rem;
      border-radius: 4px;
    }

    .control-group {
      margin-bottom: 1.25rem;
    }

    .label-control {
      color: #666;
      font-weight: bold;
      font-size: 0.7rem;
      display: block;
      margin-bottom: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .label-voice {
      color: #ea580c;
    }

    .antonov-input {
      width: 100%;
      background: #111;
      border: 1px solid #333;
      color: white;
      padding: 0.75rem;
      font-family: 'Space Mono', monospace;
      font-size: 0.85rem;
      outline: none;
      border-radius: 4px;
    }

    .antonov-input:focus {
      border-color: #ea580c;
    }

    textarea.antonov-input {
      resize: vertical;
      min-height: 80px;
    }

    .voice-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem;
    }

    .v-btn {
      background: #111;
      border: 2px solid #222;
      padding: 1rem;
      cursor: pointer;
      font-size: 2rem;
      filter: grayscale(1);
      transition: all 0.3s;
      display: flex;
      align-items: center;
      justify-content: center;
      aspect-ratio: 1;
      border-radius: 8px;
    }

    .v-btn:hover {
      border-color: #555;
      transform: translateY(-4px);
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
    }

    .v-btn.active {
      border-color: #ea580c;
      background: linear-gradient(135deg, #1a1a1a 0%, #0a0a0a 100%);
      filter: grayscale(0);
      transform: scale(1.1) translateY(-2px);
      box-shadow: 0 0 25px rgba(234, 88, 12, 0.5), 0 8px 20px rgba(0, 0, 0, 0.4);
    }

    .antonov-btn {
      width: 100%;
      padding: 0.9rem;
      font-weight: 900;
      text-transform: uppercase;
      cursor: pointer;
      border: none;
      transition: all 0.2s;
      font-size: 0.75rem;
      letter-spacing: 1.5px;
      border-radius: 4px;
      font-family: 'Inter', sans-serif;
    }

    .btn-gemini {
      background: linear-gradient(135deg, #ea580c 0%, #c2410c 100%);
      color: #000;
      margin-bottom: 0.5rem;
      font-weight: 900;
      box-shadow: 0 4px 15px rgba(234, 88, 12, 0.3);
    }

    .btn-gemini:hover:not(:disabled) {
      background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(234, 88, 12, 0.5);
    }

    .btn-random {
      background: #18181b;
      color: #a1a1aa;
    }

    .btn-random:hover {
      background: #27272a;
    }

    .btn-download {
      background: linear-gradient(135deg, #16a34a 0%, #15803d 100%);
      color: white;
      margin-top: 0.5rem;
      font-weight: 900;
      box-shadow: 0 4px 15px rgba(22, 163, 74, 0.3);
    }

    .btn-download:hover {
      background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(22, 163, 74, 0.5);
    }

    .antonov-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .canvas-container {
      background: linear-gradient(135deg, #0a0a0a 0%, #000 100%);
      border: 2px solid #222;
      padding: 2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 550px;
      border-radius: 8px;
      position: relative;
      overflow: hidden;
    }

    .canvas-container::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: radial-gradient(circle at center, transparent 0%, rgba(234, 88, 12, 0.05) 100%);
      pointer-events: none;
    }

    canvas {
      max-width: 100%;
      height: auto !important;
      border: 1px solid #333;
      box-shadow: 0 10px 50px rgba(0, 0, 0, 0.8), 0 0 30px rgba(234, 88, 12, 0.1);
      position: relative;
      z-index: 1;
    }

    .slider-container {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .slider-container input {
      flex: 1;
      accent-color: #ea580c;
    }

    .size-display {
      font-family: 'Space Mono', monospace;
      color: #ea580c;
      font-weight: bold;
      min-width: 55px;
      text-align: center;
      font-size: 0.8rem;
    }

    .divider {
      border-top: 1px solid #222;
      padding-top: 1.25rem;
      margin-top: 0.5rem;
    }

    select.antonov-input {
      margin-bottom: 0.5rem;
    }

    @media (max-width: 1024px) {
      .antonov-container {
        padding: 1.5rem;
      }

      .voice-grid {
        gap: 0.4rem;
      }

      .v-btn {
        font-size: 1.1rem;
        padding: 0.6rem;
      }
    }
  </style>

  <div class="antonov-wrapper">
    <div class="antonov-container">
      <section class="antonov-body">
        <div class="header-section">
          <h1 class="header-title">ANTONOV V5.0</h1>
          <p class="header-subtitle">
            SISTEMA MULTI-NÚCLEO // <span id="current-voice-name" class="voice-name-display">SAPO HONESTO</span>
          </p>
        </div>

        <div class="system-grid">
          <aside class="antonov-panel">
            <div class="control-group">
              <label class="label-control label-voice">◢ SELECCIONAR NÚCLEO:</label>
              <div class="voice-grid">
                <button class="v-btn active" data-voice="sapo" title="Sapo Honesto">🐸</button>
                <button class="v-btn" data-voice="coach" title="Coach Sin Azúcar">🥊</button>
                <button class="v-btn" data-voice="zen" title="Zen Callejero">🕶️</button>
              </div>
            </div>

            <div class="control-group">
              <label class="label-control">▸ Palabras Clave o Tema:</label>
              <input 
                type="text" 
                id="keywords" 
                class="antonov-input" 
                placeholder="Ej: dinero, disciplina, paz..."
                style="margin-bottom: 0.5rem;"
              />
              <label class="label-control" style="font-size: 0.6rem; color: #666; margin-top: 0;">
                Escribe el tema y el núcleo genera su versión
              </label>
            </div>

            <div class="control-group">
              <label class="label-control">▸ Texto del Núcleo:</label>
              <textarea id="quote" class="antonov-input" placeholder="SISTEMA LISTO..."></textarea>
            </div>

            <div class="control-group">
              <button id="btn-gemini" class="antonov-btn btn-gemini">
                <span id="btn-text">🤖 GENERAR CON GEMINI</span>
              </button>
              <button id="btn-random" class="antonov-btn btn-random">🎲 FRASE ALEATORIA</button>
            </div>

            <div class="control-group divider">
              <label class="label-control">▸ Tamaño de Fuente:</label>
              <div class="slider-container">
                <input type="range" id="fontSizeSlider" min="20" max="300" value="80" />
                <span id="sizeVal" class="size-display">80px</span>
              </div>
            </div>

            <div class="control-group">
              <label class="label-control">▸ Formato:</label>
              <select id="format" class="antonov-input">
                <option value="post">CUADRADO (1080x1080)</option>
                <option value="story">STORY (1080x1920)</option>
                <option value="banner">BANNER (1920x1080)</option>
              </select>

              <label class="label-control" style="margin-top: 0.5rem">▸ Intensidad Glitch:</label>
              <select id="intensity" class="antonov-input">
                <option value="0.5">BAJO</option>
                <option value="1.0" selected>ALTO</option>
                <option value="1.5">EXTREMO</option>
              </select>
            </div>

            <button id="btn-download" class="antonov-btn btn-download">⬇ DESCARGAR IMAGEN</button>
          </aside>

          <section class="canvas-container">
            <canvas id="canvas"></canvas>
          </section>
        </div>
      </section>
    </div>
  </div>

  <script is:inline>
    // Envolvemos todo en una función inicializadora
    function initAntonovSystem() {
      const canvas = document.getElementById('canvas');
      
      // Si no existe el canvas (estamos en otra página), no hacemos nada
      if (!canvas) return; 

      const ctx = canvas.getContext('2d');

      const el = {
        format: document.getElementById('format'),
        quote: document.getElementById('quote'),
        keywords: document.getElementById('keywords'),
        intensity: document.getElementById('intensity'),
        slider: document.getElementById('fontSizeSlider'),
        sizeVal: document.getElementById('sizeVal'),
        btnGemini: document.getElementById('btn-gemini'),
        btnText: document.getElementById('btn-text'),
        btnRandom: document.getElementById('btn-random'),
        btnDownload: document.getElementById('btn-download'),
        voiceButtons: document.querySelectorAll('[data-voice]'),
        voiceName: document.getElementById('current-voice-name'),
      };

      // PROMPTS AFINADOS Y AGRESIVOS
      const personalidades = {
        sapo: {
          nombre: 'SAPO HONESTO',
          color: '#22c55e',
          prompt: (keywords) =>
            `Actúa como un 'Sapo de Barrio' cínico, materialista y brutalmente honesto. Odias el romanticismo y las excusas. El usuario te da el tema: "${keywords}".
            Tu tarea: Genera UNA frase corta (máximo 6 palabras) que golpee con realidad cruda.
            Estilo: "La plata no tiene amigos", "El amor no paga arriendo".
            Respuesta: Solo la frase en MAYÚSCULAS. Nada más.`,
          frases: [
            'MENOS LENGUA MÁS BILLETE',
            'EL AMOR NO PAGA ARRIENDO',
            'TU OPINIÓN NO FACTURA',
            'LLORAR NO IMPRIME DINERO',
            'PRIMERO LA PLATA LUEGO TÚ',
          ],
        },
        coach: {
          nombre: 'COACH SIN AZÚCAR',
          color: '#ef4444',
          prompt: (keywords) =>
            `Actúa como un entrenador militar psicópata que odia la debilidad. El usuario te da el tema: "${keywords}".
            Tu tarea: Genera UNA orden o insulto motivacional (máximo 6 palabras) que duela pero active.
            Estilo: "Vomita o sigue", "Tu dolor no me importa".
            Respuesta: Solo la frase en MAYÚSCULAS. Nada más.`,
          frases: [
            'EL DOLOR ES TU AMIGO',
            'DESCANSAR ES PARA MUERTOS',
            'NADIE VENDRÁ A SALVARTE',
            'TUS EXCUSAS ME ASQUEAN',
            'SUFRE AHORA GANA LUEGO',
          ],
        },
        zen: {
  nombre: 'ZEN CALLEJERO',
  color: '#a855f7',
  prompt: (keywords) =>
    `Actúa como un maestro estoico urbano y sofisticado. El usuario te da el tema: "${keywords}".
    Tu tarea: Genera UNA sentencia de Causa y Efecto (máximo 8 palabras) que conecte la mentalidad con el resultado.
    Estilo: "Una mente clara produce una acción certera", "Si controlas tu mente controlas tu dinero".
    Respuesta: Solo la frase en MAYÚSCULAS. Nada más.`,
  frases: [
    'MENTE CLARA ACCIÓN CERTERA',
    'SI DUDAS PIERDES',
    'EL CAOS INTERNO CREA POBREZA EXTERNA',
    'CALMA TU MENTE DOMINA TU JUEGO',
    'LO QUE PIENSAS LO FACTURAS',
    ],
   },
  };

      let selectedVoice = 'sapo';

      const render = () => {
        if (!el.format || !el.quote) return; // Protección extra

        const format = el.format.value;
        const text = (el.quote.value || 'SISTEMA LISTO').toUpperCase();
        const intensity = parseFloat(el.intensity.value || 1.0);
        const fontSize = parseInt(el.slider.value || 80);
        const per = personalidades[selectedVoice];
        
        if (el.sizeVal) el.sizeVal.innerText = fontSize + 'px';

        let w = 1080, h = 1080;
        if (format === 'story') { w = 1080; h = 1920; }
        if (format === 'banner') { w = 1920; h = 1080; }
        
        canvas.width = w;
        canvas.height = h;

        // Fondo
        ctx.fillStyle = '#000';
        ctx.fillRect(0, 0, w, h);
        
        // Config texto
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.font = `900 ${fontSize}px monospace`;

        // Word wrap
        const words = text.split(' ');
        let lines = [], currentLine = words[0];
        for (let i = 1; i < words.length; i++) {
          if (ctx.measureText(currentLine + ' ' + words[i]).width < w * 0.85) {
            currentLine += ' ' + words[i];
          } else {
            lines.push(currentLine);
            currentLine = words[i];
          }
        }
        lines.push(currentLine);

        // Renderizado Glitch
        const lineHeight = fontSize * 1.15;
        const totalHeight = lines.length * lineHeight;
        const startY = h / 2 - totalHeight / 2 + fontSize / 2;

        lines.forEach((line, i) => {
          const y = startY + i * lineHeight;
          const offset = 8 * intensity;
          
          // Capa Roja (Glitch)
          ctx.fillStyle = 'rgba(255, 0, 0, 0.7)';
          ctx.fillText(line, w / 2 + offset, y);
          
          // Capa Cyan (Glitch)
          ctx.fillStyle = 'rgba(0, 255, 255, 0.7)';
          ctx.fillText(line, w / 2 - offset, y);
          
          // Capa Blanca (Principal)
          ctx.fillStyle = '#fff';
          ctx.fillText(line, w / 2, y);
        });

        // Borde y Firma
        ctx.strokeStyle = per.color;
        ctx.lineWidth = 12;
        ctx.strokeRect(25, 25, w - 50, h - 50);
        
        ctx.fillStyle = per.color;
        ctx.font = `bold ${w * 0.025}px monospace`;
        ctx.fillText(`>>> ${per.nombre} <<<`, w / 2, h - 60);
      };

      const callGemini = async () => {
        const keywords = el.keywords.value.trim();
        
        if (!keywords) {
          alert('⚠️ Escribe palabras clave primero (ej: dinero, éxito, paz)');
          return;
        }

        const per = personalidades[selectedVoice];
        el.btnGemini.disabled = true;
        el.btnText.textContent = '⏳ GENERANDO...';
        
        try {
          const response = await fetch('https://mis-frases.poderparatriunfar.workers.dev/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ prompt: per.prompt(keywords) }),
          });
          const data = await response.json();
          if (!response.ok) throw new Error(data.error || `Error ${response.status}`);
          
          el.quote.value = data.text.toUpperCase();
          render();
        } catch (error) {
          console.error('Error:', error);
          alert(`❌ Error: ${error.message}`);
        } finally {
          el.btnGemini.disabled = false;
          el.btnText.textContent = '🤖 GENERAR CON GEMINI';
        }
      };

      // Event Listeners
      el.voiceButtons.forEach((btn) => {
        btn.onclick = (e) => {
          e.preventDefault();
          el.voiceButtons.forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          selectedVoice = btn.getAttribute('data-voice');
          if (el.voiceName) el.voiceName.innerText = personalidades[selectedVoice].nombre;
          render();
        };
      });

      [el.format, el.intensity, el.slider, el.quote].forEach((input) => {
        if (input) input.oninput = render;
      });

      if (el.btnGemini) el.btnGemini.onclick = callGemini;

      if (el.btnRandom) {
        el.btnRandom.onclick = () => {
          const frases = personalidades[selectedVoice].frases;
          el.quote.value = frases[Math.floor(Math.random() * frases.length)];
          render();
        };
      }

      if (el.btnDownload) {
        el.btnDownload.onclick = () => {
          const link = document.createElement('a');
          link.download = `ANTONOV-${selectedVoice}-${Date.now()}.png`;
          link.href = canvas.toDataURL();
          link.click();
        };
      }

      // Render inicial
      render();
    }

    // 🔥 EL SECRETO: Ejecutar en carga inicial Y en navegación de Astro
    document.addEventListener('astro:page-load', initAntonovSystem);
    
    // Fallback por si acaso no usas View Transitions en alguna parte
    initAntonovSystem();
  </script>
</Layout>