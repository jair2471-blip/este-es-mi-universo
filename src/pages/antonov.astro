---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'ANTONOV PRO | Elite Mindset',
  description: 'La conciencia artificial de los líderes.',
};
---

<Layout metadata={metadata}>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;700;900&family=Space+Grotesk:wght@700&display=swap');

    body {
      background: #050505;
      background-image: 
        radial-gradient(at 0% 0%, rgba(255, 215, 0, 0.03) 0px, transparent 50%),
        radial-gradient(at 100% 100%, rgba(255, 255, 255, 0.01) 0px, transparent 50%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
      font-family: 'Inter', sans-serif;
      margin: 0;
    }

    .app-window {
      width: 100%;
      max-width: 1000px;
      background: #0a0a0a;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 40px 80px rgba(0,0,0,0.9);
      display: flex;
      flex-direction: column;
    }

    /* 🔥 CORRECCIÓN DEL HEADER 🔥 */
    .app-bar {
      height: 50px;
      padding: 0 20px;
      background: rgba(255, 255, 255, 0.02);
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      display: flex;
      align-items: center;
      justify-content: center; /* Centra el título */
      position: relative; /* Para anclar los botones */
    }

    .window-controls {
      position: absolute;
      left: 20px;
      display: flex;
      gap: 8px;
    }
    
    .dot { width: 12px; height: 12px; border-radius: 50%; background: #222; transition: 0.2s; }
    .dot:hover { background: #444; }
    .dot.close { background: #ff5f56; }
    .dot.min { background: #ffbd2e; }
    .dot.max { background: #27c93f; }

    .app-title {
      color: #666;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 3px;
      text-transform: uppercase;
      font-family: 'Space Grotesk', sans-serif;
    }

    /* Resto del diseño igual de berraco */
    .system-grid {
      display: grid;
      grid-template-columns: 1fr;
    }

    @media (min-width: 900px) {
      .system-grid { grid-template-columns: 350px 1fr; }
    }

    .side-panel {
      padding: 30px;
      border-right: 1px solid rgba(255, 255, 255, 0.05);
      display: flex;
      flex-direction: column;
      gap: 20px;
      background: #0c0c0c;
    }

    .brand h1 { font-family: 'Bebas Neue', cursive; font-size: 3rem; color: #fff; margin: 0; line-height: 1; }
    .brand p { color: #ffd700; font-size: 0.65rem; letter-spacing: 2px; font-weight: 700; margin-top: 5px; }

    .control-group { display: flex; flex-direction: column; gap: 8px; }
    .control-group label { color: #444; font-size: 0.6rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; }

    textarea, select, input[type="range"] {
      background: #111;
      border: 1px solid #222;
      border-radius: 10px;
      color: #fff;
      padding: 12px;
      font-size: 0.85rem;
      font-family: 'Inter', sans-serif;
    }
    textarea:focus { outline: 1px solid #ffd700; }

    .btn-action {
      background: #fff;
      color: #000;
      border: none;
      padding: 15px;
      border-radius: 10px;
      font-weight: 900;
      text-transform: uppercase;
      cursor: pointer;
      transition: 0.2s;
    }
    .btn-action:hover { background: #ffd700; }

    .preview-box {
      background: #000;
      padding: 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 500px;
      position: relative;
    }

    canvas {
      max-width: 100%;
      height: auto;
      border-radius: 4px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.5);
    }

    .loading { opacity: 0.5; pointer-events: none; }
  </style>

  <div class="app-window">
    <div class="app-bar">
      <div class="window-controls">
        <div class="dot close"></div>
        <div class="dot min"></div>
        <div class="dot max"></div>
      </div>
      <span class="app-title">ANTONOV CORE SYSTEM v2.1</span>
    </div>

    <div class="system-grid">
      <aside class="side-panel">
        <div class="brand">
          <h1>ANTONOV</h1>
          <p>SISTEMA DE EXCELENCIA</p>
        </div>

        <div class="control-group">
          <label>Situación Actual</label>
          <textarea id="in-pregunta" rows="3" placeholder="¿Qué te detiene?"></textarea>
        </div>

        <button id="run-btn" class="btn-action">EJECUTAR SENTENCIA</button>

        <div class="control-group">
          <label>Ajustes de Arte</label>
          <select id="in-format">
            <option value="post">CUADRADO (FEED)</option>
            <option value="story">VERTICAL (STORY)</option>
          </select>
          <input type="range" id="in-size" min="50" max="150" value="100">
        </div>

        <button id="dl-btn" style="background:transparent; border:1px solid #222; color:#555;" class="btn-action">DESCARGAR PNG</button>
      </aside>

      <main class="preview-box">
        <canvas id="main-canvas"></canvas>
        <input type="hidden" id="hidden-res">
      </main>
    </div>
  </div>

  <script is:inline>
    function startSystem() {
      const canvas = document.getElementById('main-canvas');
      const ctx = canvas.getContext('2d');
      const ui = {
        q: document.getElementById('in-pregunta'),
        r: document.getElementById('hidden-res'),
        fmt: document.getElementById('in-format'),
        sz: document.getElementById('in-size'),
        btn: document.getElementById('run-btn'),
        dl: document.getElementById('dl-btn')
      };

      const render = () => {
        const isStory = ui.fmt.value === 'story';
        const w = 1080;
        const h = isStory ? 1920 : 1080;
        canvas.width = w; canvas.height = h;

        ctx.fillStyle = '#000';
        ctx.fillRect(0, 0, w, h);

        for(let i=0; i<6000; i++){
          ctx.fillStyle = `rgba(255,255,255,${Math.random()*0.02})`;
          ctx.fillRect(Math.random()*w, Math.random()*h, 1, 1);
        }

        const qText = ui.q.value.trim().toUpperCase();
        if(qText) {
          ctx.font = "600 32px 'Inter'";
          ctx.fillStyle = "rgba(255,255,255,0.3)";
          ctx.textAlign = "center";
          drawWrappedText(ctx, qText, w/2, 120, w*0.8, 45, false);
        }

        const rText = (ui.r.value || "ANTONOV ESTÁ ESCUCHANDO...").toUpperCase();
        const fSize = parseInt(ui.sz.value);
        ctx.font = `900 ${fSize}px 'Bebas Neue'`;
        ctx.fillStyle = "#fff";
        ctx.textAlign = "center";
        drawWrappedText(ctx, rText, w/2, h/2, w*0.85, fSize * 1.05, true);

        ctx.font = "700 24px 'Inter'";
        ctx.fillStyle = "#ffd700";
        ctx.letterSpacing = "10px";
        ctx.fillText("EL UNIVERSO DE LA MENTE", w/2, h - 100);
      };

      function drawWrappedText(context, text, x, y, maxWidth, lineHeight, centerV) {
        const words = text.split(' ');
        let lines = [];
        let currentLine = '';

        for (let n = 0; n < words.length; n++) {
          let testLine = currentLine + words[n] + ' ';
          let metrics = context.measureText(testLine);
          if (metrics.width > maxWidth && n > 0) {
            lines.push(currentLine);
            currentLine = words[n] + ' ';
          } else { currentLine = testLine; }
        }
        lines.push(currentLine);

        let startY = centerV ? y - ((lines.length - 1) * lineHeight) / 2 : y;
        lines.forEach(line => {
          context.fillText(line.trim(), x, startY);
          startY += lineHeight;
        });
      }

      ui.btn.onclick = async () => {
        if(!ui.q.value) return alert("Escribe algo, compa.");
        ui.btn.innerText = "SINTONIZANDO...";
        ui.btn.classList.add('loading');

        try {
          const res = await fetch('https://mis-frases.poderparatriunfar.workers.dev/', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ prompt: `Responde como Antonov (Cornejo). Contexto: "${ui.q.value}". 2 frases cortas, crudas, en mayúsculas.`})
          });
          const data = await res.json();
          ui.r.value = data.text;
          render();
        } catch (e) { alert("Falla en la matriz."); }
        finally {
          ui.btn.innerText = "EJECUTAR SENTENCIA";
          ui.btn.classList.remove('loading');
        }
      };

      ui.sz.oninput = render;
      ui.fmt.onchange = render;
      ui.dl.onclick = () => {
        const link = document.createElement('a');
        link.download = 'ANTONOV_SENTENCIA.png';
        link.href = canvas.toDataURL('image/png');
        link.click();
      };

      render();
    }

    document.addEventListener('astro:page-load', startSystem);
    startSystem();
  </script>
</Layout>