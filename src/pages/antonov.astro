---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'ORÁCULO DE LA MENTE | Sentencias de Calle',
  description: 'Pregunta sin miedo. El Oráculo responde directo.',
};
---

<Layout metadata={metadata}>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;900&family=Space+Mono:wght@700&display=swap');

    body {
      background: #0a0a0a;
    }

    .oraculo-wrapper {
      max-width: 1200px;
      margin: 2rem auto;
      padding: 0 1rem;
      min-height: calc(100vh - 4rem);
      display: flex;
      align-items: center;
    }

    .oraculo-container {
      background: #000;
      border: 3px solid #fff;
      border-radius: 0;
      padding: 2.5rem;
      box-shadow: 0 30px 80px rgba(255, 255, 255, 0.15), 0 0 100px rgba(255, 255, 255, 0.05);
      width: 100%;
    }

    .oraculo-body {
      color: white;
      font-family: 'Inter', sans-serif;
    }

    .header-section {
      text-align: center;
      margin-bottom: 2rem;
      border-bottom: 2px solid #222;
      padding-bottom: 1.5rem;
    }

    .header-title {
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 900;
      color: #fff;
      text-transform: uppercase;
      line-height: 0.9;
      margin-bottom: 0.75rem;
      letter-spacing: -2px;
    }

    .header-subtitle {
      color: #666;
      font-weight: bold;
      letter-spacing: 2px;
      font-size: 0.65rem;
      text-transform: uppercase;
    }

    .pregunta-display {
      margin-top: 1rem;
      padding: 1rem;
      background: #0a0a0a;
      border: 1px solid #222;
      min-height: 50px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .pregunta-text {
      color: #fff;
      font-size: 0.85rem;
      font-weight: 600;
      text-align: center;
      font-style: italic;
      letter-spacing: 0.5px;
    }

    .pregunta-text.empty {
      color: #333;
      font-style: normal;
    }

    .system-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    @media (min-width: 1024px) {
      .system-grid {
        grid-template-columns: 320px 1fr;
      }
    }

    .oraculo-panel {
      background: #0a0a0a;
      border: 2px solid #1a1a1a;
      padding: 1.5rem;
    }

    .control-group {
      margin-bottom: 1.5rem;
    }

    .label-control {
      color: #888;
      font-weight: bold;
      font-size: 0.7rem;
      display: block;
      margin-bottom: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 1.5px;
    }

    .oraculo-input {
      width: 100%;
      background: #000;
      border: 2px solid #333;
      color: white;
      padding: 1rem;
      font-family: 'Space Mono', monospace;
      font-size: 0.9rem;
      outline: none;
      transition: all 0.3s;
    }

    .oraculo-input:focus {
      border-color: #fff;
      box-shadow: 0 0 20px rgba(255, 255, 255, 0.1);
    }

    textarea.oraculo-input {
      resize: vertical;
      min-height: 140px;
      font-size: 1.1rem;
      line-height: 1.6;
    }

    .oraculo-btn {
      width: 100%;
      padding: 1.2rem;
      font-weight: 900;
      text-transform: uppercase;
      cursor: pointer;
      border: none;
      transition: all 0.3s;
      font-size: 0.8rem;
      letter-spacing: 2px;
      font-family: 'Inter', sans-serif;
      position: relative;
      overflow: hidden;
    }

    .btn-consultar {
      background: #fff;
      color: #000;
      margin-bottom: 0.75rem;
      border: 3px solid #fff;
    }

    .btn-consultar:hover:not(:disabled) {
      background: #000;
      color: #fff;
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(255, 255, 255, 0.3);
    }

    .btn-azar {
      background: #000;
      color: #666;
      border: 2px solid #333;
    }

    .btn-azar:hover {
      background: #111;
      color: #fff;
      border-color: #555;
    }

    .btn-download {
      background: #000;
      color: #fff;
      border: 2px solid #fff;
      margin-top: 1rem;
    }

    .btn-download:hover {
      background: #fff;
      color: #000;
      transform: translateY(-2px);
    }

    .oraculo-btn:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }

    .canvas-container {
      background: #0a0a0a;
      border: 2px solid #1a1a1a;
      padding: 2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 500px;
      position: relative;
    }

    canvas {
      max-width: 100%;
      height: auto !important;
      border: 1px solid #333;
      box-shadow: 0 10px 60px rgba(0, 0, 0, 0.9);
    }

    .slider-container {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .slider-container input {
      flex: 1;
      accent-color: #fff;
    }

    .size-display {
      font-family: 'Space Mono', monospace;
      color: #fff;
      font-weight: bold;
      min-width: 60px;
      text-align: center;
      font-size: 0.85rem;
    }

    .divider {
      border-top: 1px solid #222;
      padding-top: 1.5rem;
      margin-top: 1rem;
    }

    select.oraculo-input {
      margin-bottom: 0.75rem;
    }

    .helper-text {
      font-size: 0.65rem;
      color: #555;
      margin-top: 0.5rem;
      font-style: italic;
    }

    @media (max-width: 1024px) {
      .oraculo-container {
        padding: 1.5rem;
      }
    }
  </style>

  <div class="oraculo-wrapper">
    <div class="oraculo-container">
      <section class="oraculo-body">
        <div class="header-section">
          <h1 class="header-title">ORÁCULO<br/>DE LA MENTE</h1>
          <p class="header-subtitle">PREGUNTA SIN MIEDO // EL ORÁCULO RESPONDE DIRECTO</p>
          <div class="pregunta-display">
            <p id="pregunta-header" class="pregunta-text empty">Esperando tu consulta...</p>
          </div>
        </div>

        <div class="system-grid">
          <aside class="oraculo-panel">
            <div class="control-group">
              <label class="label-control">▸ ¿QUÉ TE ATORMENTA?</label>
              <input 
                type="text" 
                id="pregunta" 
                class="oraculo-input" 
                placeholder="Ej: ¿Debo renunciar? ¿Me conviene ese socio?"
              />
              <p class="helper-text">El Oráculo no juzga. Solo dice la verdad.</p>
            </div>

            <div class="control-group">
              <label class="label-control">▸ LA SENTENCIA</label>
              <textarea id="respuesta" class="oraculo-input" placeholder="AQUÍ APARECERÁ TU RESPUESTA..."></textarea>
            </div>

            <div class="control-group">
              <button id="btn-consultar" class="oraculo-btn btn-consultar">
                <span id="btn-text">👁️ CONSULTAR AL ORÁCULO</span>
              </button>
              <button id="btn-azar" class="oraculo-btn btn-azar">🎲 SENTENCIA AL AZAR</button>
            </div>

            <div class="control-group divider">
              <label class="label-control">▸ TAMAÑO DE FUENTE</label>
              <div class="slider-container">
                <input type="range" id="fontSizeSlider" min="30" max="200" value="90" />
                <span id="sizeVal" class="size-display">90px</span>
              </div>
            </div>

            <div class="control-group">
              <label class="label-control">▸ FORMATO</label>
              <select id="format" class="oraculo-input">
                <option value="post">CUADRADO (1080x1080)</option>
                <option value="story">STORY (1080x1920)</option>
                <option value="banner">BANNER (1920x1080)</option>
              </select>
            </div>

            <button id="btn-download" class="oraculo-btn btn-download">⬇ DESCARGAR SENTENCIA</button>
          </aside>

          <section class="canvas-container">
            <canvas id="canvas"></canvas>
          </section>
        </div>
      </section>
    </div>
  </div>

  <script is:inline>
    function initOraculo() {
      const canvas = document.getElementById('canvas');
      if (!canvas) return;

      const ctx = canvas.getContext('2d');

      const el = {
        format: document.getElementById('format'),
        respuesta: document.getElementById('respuesta'),
        pregunta: document.getElementById('pregunta'),
        preguntaHeader: document.getElementById('pregunta-header'),
        slider: document.getElementById('fontSizeSlider'),
        sizeVal: document.getElementById('sizeVal'),
        btnConsultar: document.getElementById('btn-consultar'),
        btnText: document.getElementById('btn-text'),
        btnAzar: document.getElementById('btn-azar'),
        btnDownload: document.getElementById('btn-download'),
      };

      // Función para detectar si es pregunta o comentario
      const formatearPregunta = (texto) => {
        if (!texto || texto.trim() === '') {
          return { texto: 'Esperando tu consulta...', isEmpty: true };
        }
        
        const limpio = texto.trim();
        
        // Detecta si es pregunta (contiene ?, qué, cuál, cómo, dónde, cuándo, por qué, debe, debo, etc)
        const esPregunta = limpio.includes('?') || 
                          /^(qué|cuál|cómo|dónde|cuándo|por qué|porqué|debe|debo|debería|puedo|podría|es bueno|conviene)/i.test(limpio);
        
        if (esPregunta) {
          // Si ya tiene signos, los respeta; si no, los agrega
          const tieneSignos = limpio.startsWith('¿') || limpio.startsWith('?');
          return { 
            texto: tieneSignos ? limpio : `¿${limpio.replace('?', '')}?`,
            isEmpty: false 
          };
        } else {
          // Es un comentario/afirmación, lo deja tal cual
          return { texto: `"${limpio}"`, isEmpty: false };
        }
      };

      // Actualizar header cuando escriba
      const actualizarHeader = () => {
        const formatted = formatearPregunta(el.pregunta.value);
        el.preguntaHeader.textContent = formatted.texto;
        
        if (formatted.isEmpty) {
          el.preguntaHeader.classList.add('empty');
        } else {
          el.preguntaHeader.classList.remove('empty');
        }
      };

      // 🔥 PROMPT DEL ORÁCULO 🔥
      const promptOraculo = (pregunta) => `
ERES EL ORÁCULO DE LA MENTE.

EL USUARIO TE DICE: "${pregunta}"

REGLAS:
1. DOS FRASES CORTAS Y CONTUNDENTES.
2. TODO EN MAYÚSCULAS.
3. DIRECTO AL HUESO, SIN RODEOS.
4. NADA DE METÁFORAS, POESÍA NI CUENTOS.
5. NO EXPLIQUES. NO TE JUSTIFIQUES.
6. NO HUMILLES NI JUZGUES CON MALDAD.
7. RESPONDE DESDE LA EXPERIENCIA DE LA CALLE, NO DESDE EL LIBRO.
8. DI LA CONSECUENCIA REAL, LA QUE TODO EL MUNDO SABE PERO NO DICE.
9. NO SERMONEES. NO DES CONSEJOS TIBIOS. DI LA VERDAD INCÓMODA.
10. SI LA PERSONA YA DECIDIÓ HACER ALGO DESTRUCTIVO, MUÉSTRALE EL COSTO REAL.
11. CADA FRASE DEBE SONAR NATURAL, COMO SI LA DIJERA UNA PERSONA NORMAL.
12. NO PREGUNTES, DECLARA. NO SUGIERAS, ADVIERTE.

ESTILO:
- COMO LE HABLARÍAS A UN AMIGO QUE NECESITA QUE LE DIGAN LA NETA.
- PRIMERA FRASE: LA VERDAD CRUDA (MÁXIMO 8 PALABRAS).
- SEGUNDA FRASE: LA CONSECUENCIA PRÁCTICA (MÁXIMO 8 PALABRAS).
- FIRME Y DIRECTO, SIN ANDAR CON RODEOS.
- SIN GROSERIAS, SIN SARCASMO, SIN MELODRAMA.
- HABLA COMO PERSONA, NO COMO ROBOT ARMANDO PALABRAS.
`;

      // Frases de respaldo
      const sentencias = [
        'LO QUE ESCONDES SIEMPRE COBRA FACTURA. TARDE O TEMPRANO PAGAS.',
        'SI TIENES QUE PREGUNTAR ES PORQUE YA SABES LA RESPUESTA.',
        'EL DINERO NO TIENE AMIGOS. SOLO TIENE INTERESES.',
        'NO ESPERES LEALTAD DE GENTE BARATA. ESO CUESTA CARO.',
        'LO QUE NIEGAS TE SOMETE. LO QUE ACEPTAS TE LIBERA.',
        'SI FUERZAS LA PUERTA ES PORQUE NO ES TU CAMINO.',
        'EL SILENCIO A VECES GRITA MÁS FUERTE QUE LAS PALABRAS.',
        'NO ES MALA SUERTE. SON CONSECUENCIAS DE MALAS DECISIONES.',
      ];

      const render = () => {
        if (!el.format || !el.respuesta) return;

        const format = el.format.value;
        const text = (el.respuesta.value || 'HAZ TU PREGUNTA AL ORÁCULO...').toUpperCase();
        const fontSize = parseInt(el.slider.value || 90);

        if (el.sizeVal) el.sizeVal.innerText = fontSize + 'px';

        let w = 1080, h = 1080;
        if (format === 'story') { w = 1080; h = 1920; }
        if (format === 'banner') { w = 1920; h = 1080; }

        canvas.width = w;
        canvas.height = h;

        // Fondo Negro Absoluto
        ctx.fillStyle = '#000';
        ctx.fillRect(0, 0, w, h);

        // Config texto
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.font = `900 ${fontSize}px 'Space Mono', monospace`;

        const words = text.split(' ');
        let lines = [], currentLine = words[0];
        for (let i = 1; i < words.length; i++) {
          if (ctx.measureText(currentLine + ' ' + words[i]).width < w * 0.85) {
            currentLine += ' ' + words[i];
          } else {
            lines.push(currentLine);
            currentLine = words[i];
          }
        }
        lines.push(currentLine);

        const lineHeight = fontSize * 1.2;
        const totalHeight = lines.length * lineHeight;
        const startY = h / 2 - totalHeight / 2 + fontSize / 2;

        // Texto Blanco Puro
        lines.forEach((line, i) => {
          const y = startY + i * lineHeight;
          ctx.fillStyle = '#fff';
          ctx.fillText(line, w / 2, y);
        });

        // Marco blanco
        ctx.strokeStyle = '#fff';
        ctx.lineWidth = 6;
        ctx.strokeRect(40, 40, w - 80, h - 80);

        // Firma abajo
        ctx.fillStyle = '#fff';
        ctx.font = `bold ${w * 0.025}px 'Inter', sans-serif`;
        ctx.fillText('/// ORÁCULO DE LA MENTE ///', w / 2, h - 70);
      };

      const callGemini = async () => {
        const pregunta = el.pregunta.value.trim();

        if (!pregunta) {
          alert('⚠️ El Oráculo no adivina. Escribe tu pregunta.');
          return;
        }

        el.btnConsultar.disabled = true;
        el.btnText.textContent = '🔮 CONSULTANDO...';

        try {
          const response = await fetch('https://mis-frases.poderparatriunfar.workers.dev/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ prompt: promptOraculo(pregunta) }),
          });
          const data = await response.json();
          if (!response.ok) throw new Error(data.error || `Error ${response.status}`);

          el.respuesta.value = data.text.toUpperCase();
          render();
        } catch (error) {
          console.error('Error:', error);
          alert(`❌ El Oráculo está en silencio: ${error.message}`);
        } finally {
          el.btnConsultar.disabled = false;
          el.btnText.textContent = '👁️ CONSULTAR AL ORÁCULO';
        }
      };

      [el.format, el.slider, el.respuesta].forEach((input) => {
        if (input) input.oninput = render;
      });

      // Actualizar header en tiempo real
      if (el.pregunta) {
        el.pregunta.oninput = actualizarHeader;
      }

      if (el.btnConsultar) el.btnConsultar.onclick = callGemini;

      if (el.btnAzar) {
        el.btnAzar.onclick = () => {
          el.respuesta.value = sentencias[Math.floor(Math.random() * sentencias.length)];
          render();
        };
      }

      if (el.btnDownload) {
        el.btnDownload.onclick = () => {
          const link = document.createElement('a');
          link.download = `ORACULO-${Date.now()}.png`;
          link.href = canvas.toDataURL();
          link.click();
        };
      }

      render();
    }

    document.addEventListener('astro:page-load', initOraculo);
    initOraculo();
  </script>
</Layout>