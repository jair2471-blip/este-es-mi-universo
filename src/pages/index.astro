---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
---

<Layout metadata={{ title: 'El Universo de la Mente' }}>
  <Hero
    tagline="Bienvenidos al vacío"
    title="EL UNIVERSO DE LA <span class='text-red-700'>MENTE</span>"
    subtitle="Donde la honestidad brutal se encuentra con el caos controlado. No es apto para mentes frágiles."
    actions={[
      {
        variant: 'primary',
        text: 'Leer el Manifiesto',
        href: '/elmanifiesto',
        class: 'bg-red-700 hover:bg-red-800 border-none text-white font-bold'
      },
    ]}
    image={{ 
      src: 'https://images.unsplash.com/photo-1550684848-fac1c5b4e853?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', 
      alt: 'Fondo oscuro abstracto' 
    }}
  />
</Layout>

<style is:global>
  /* Este es el truco para que el fondo sea negro total y las letras resalten */
  body {
    background-color: #000000 !important;
  }
  h1 {
    letter-spacing: -0.05em;
    line-height: 0.9 !important;
    text-transform: uppercase;
  }
</style>
