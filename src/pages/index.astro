---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';

const metadata = {
  title: 'El Universo de la Mente | Honestidad Brutal',
};
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      { variant: 'primary', text: 'Empezar a leer', href: '/blog', icon: 'tabler:arrow-right' },
    ]}
    image={{ src: 'https://images.unsplash.com/photo-1518066000714-58c45f1a2c0a?q=80&w=2070', alt: 'Universo' }}
  >
    <Fragment slot="title">
      Despierta del <span class="text-accent dark:text-white highlight">SUEÑO</span>: <br /> 
      Rediseña tu Realidad
    </Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold text-xl italic">
        "Usted no necesita motivación, usted necesita disciplina y dejar de hacerse el loco."
      </span>
    </Fragment>
  </Hero>

  <Features
    id="features"
    tagline="Principios"
    title="Lo que vas a encontrar aquí"
    items={[
      {
        title: 'Psicología Sin Filtros',
        description: 'Análisis reales sobre por qué hacemos lo que hacemos, sin azúcar añadida.',
        icon: 'tabler:brain',
      },
      {
        title: 'Filosofía Práctica',
        description: 'Herramientas de los antiguos para los problemas de hoy.',
        icon: 'tabler:sword',
      },
    ]}
  />

  <BlogLatestPosts
    title="Últimas Reflexiones del Abismo"
    information="Cada post es una herramienta para tu transformación."
  />
</Layout>
