---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
---

<Layout metadata={{ title: 'E.U.L.M | El Universo de la Mente' }}>
  <Hero
    tagline="Bienvenidos al vacío"
    actions={[
      {
        variant: 'primary',
        text: 'Leer el Manifiesto',
        href: '/elmanifiesto',
        class: 'bg-red-700 hover:bg-red-800 border-none text-white font-bold'
      },
    ]}
  >
    <Fragment slot="title">
      <span class="text-white">EL UNIVERSO DE LA</span> <span class="text-red-700">MENTE</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="text-slate-200 block mt-4">
        Donde la honestidad brutal se encuentra con el caos controlado. <br class="hidden md:block" />
        No es apto para mentes frágiles.
      </span>
    </Fragment>
  </Hero>
</Layout>

<style is:global>
  /* 1. FUNDACIÓN DEL VACÍO (Negro Absoluto) */
  html, body, main {
    background-color: #000000 !important;
    color: #ffffff !important;
  }

  /* 2. TIPOGRAFÍA E.U.L.M (Brutalismo) */
  h1 {
    font-weight: 900 !important;
    letter-spacing: -0.06em !important; 
    line-height: 0.85 !important;
    text-transform: uppercase;
  }

  /* 3. COLORES BLINDADOS */
  h1, p, span, a, .text-muted, li {
    color: #ffffff !important;
  }

  .text-red-700, .text-primary {
    color: #b91c1c !important;
  }

  /* 4. ESTILO PARA LA BITÁCORA (Blog List) */
  /* Esto hace que cada post en la lista se vea como un bloque sólido */
  article {
    background-color: #000000 !important;
    border-bottom: 2px solid #1a1a1a !important;
    padding-bottom: 2rem;
    margin-bottom: 2rem;
  }

  article h2 a {
    color: #ffffff !important;
    font-weight: 800 !important;
    text-transform: uppercase;
    letter-spacing: -0.03em;
  }

  article h2 a:hover {
    color: #b91c1c !important;
  }

  /* 5. LIMPIEZA DE INTERFAZ */
  [data-aw-toggle-color-scheme] {
    display: none !important; /* Fuera botón de modo claro */
  }

  header, footer {
    background-color: #000000 !important;
    border-color: #1a1a1a !important;
  }

  /* Aseguramos que los links del menú no se pierdan */
  header a:hover {
    color: #b91c1c !important;
  }
</style>