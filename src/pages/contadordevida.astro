---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Contador de Vida | El Universo de la Mente',
};
---

<Layout metadata={metadata}>
  <section class="bg-[#0a0a0a] text-[#f4f4f4] min-h-screen font-['Rajdhani'] relative overflow-hidden py-20">
    <div id="particles-js" class="absolute inset-0 z-0 pointer-events-none opacity-20"></div>

    <div class="container mx-auto px-4 relative z-10">
      <header class="text-center mb-16">
        <h1 class="glitch text-5xl md:text-7xl font-bold mb-4 tracking-tighter text-white" data-text="TU VIDA SE ESTÁ DESCARGANDO">
          TU VIDA SE ESTÁ DESCARGANDO
        </h1>
        <p class="subtitle font-mono text-orange-500 tracking-widest uppercase">>>> CADA SEGUNDO CUENTA. ¿O NO? <<<</p>
      </header>

      <section id="age-input-section" class="max-w-2xl mx-auto text-center p-10 bg-[#1a1a1a] border border-orange-500/20 rounded-2xl backdrop-blur-md shadow-2xl">
        <h2 class="text-3xl font-bold mb-6 text-orange-500">¿CUÁNTOS AÑOS TIENES?</h2>
        <div class="flex flex-col md:flex-row justify-center items-center gap-6">
          <input 
            type="number" 
            id="age-input" 
            min="1" 
            max="100" 
            placeholder="25" 
            class="text-4xl font-bold p-4 bg-[#2D3142] border-2 border-orange-500 rounded-xl text-center w-32 focus:outline-none focus:ring-4 focus:ring-orange-500/50 transition-all"
          />
          <button 
            id="btn-calculate"
            class="bg-gradient-to-r from-orange-600 to-orange-400 text-black font-bold py-5 px-10 rounded-xl text-xl hover:scale-105 transition-transform shadow-lg uppercase"
          >
            Mostrarme la Realidad
          </button>
        </div>
      </section>

      <div id="counters" class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-16 hidden">
        </div>

      <div id="brutal-phrases" class="max-w-4xl mx-auto mt-20 text-center">
        </div>
    </div>
  </section>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;700&family=Share+Tech+Mono&display=swap');
    
    .glitch {
      position: relative;
      animation: glitch-anim 3s infinite;
    }
    .glitch::before, .glitch::after {
      content: attr(data-text);
      position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    }
    .glitch::before { left: 2px; text-shadow: -2px 0 #ff6b35; clip: rect(44px, 450px, 56px, 0); animation: glitch-1 2s infinite linear alternate-reverse; }
    .glitch::after { left: -2px; text-shadow: 2px 0 #00fff9; clip: rect(100px, 450px, 120px, 0); animation: glitch-2 3s infinite linear alternate-reverse; }

    @keyframes glitch-1 { 0% { clip: rect(10px, 999px, 40px, 0); } 100% { clip: rect(80px, 999px, 100px, 0); } }
    @keyframes glitch-2 { 0% { clip: rect(50px, 999px, 70px, 0); } 100% { clip: rect(10px, 999px, 30px, 0); } }

    .counter-card {
      background: linear-gradient(145deg, #1a1a1a, #2D3142);
      border: 1px solid rgba(255, 107, 53, 0.3);
      padding: 2rem;
      border-radius: 1.25rem;
      text-align: center;
      transition: all 0.3s ease;
    }
    .counter-card:hover { border-color: #ff6b35; transform: translateY(-5px); }
    
    .phrase-box {
      font-size: 1.8rem;
      border-left: 4px solid #ff6b35;
      padding: 1.5rem;
      background: rgba(255,107,53, 0.05);
      margin-bottom: 1.5rem;
      opacity: 0;
      animation: fadeIn 0.8s forwards;
    }
    @keyframes fadeIn { to { opacity: 1; } }
  </style>

  <script is:inline>
    const btn = document.getElementById('btn-calculate');
    const input = document.getElementById('age-input');
    const countersContainer = document.getElementById('counters');
    const phrasesContainer = document.getElementById('brutal-phrases');

    const brutalPhrases = [
      "Mientras leías esto, perdiste tiempo que no volverá jamás.",
      "Mañana es la mentira favorita de los mediocres.",
      "Estás más cerca del final que del principio. ¿Qué vas a hacer?",
      "Tu vida no es un ensayo. Estás en plena función.",
      "¿Cuántos de tus días realmente valen la pena recordar?"
    ];

    btn.addEventListener('click', () => {
      const age = parseInt(input.value);
      if (!age || age < 1 || age > 100) return alert('Pon una edad real, compa.');

      const lifeExp = 80;
      const left = lifeExp - age;
      
      const data = [
        { label: 'Días restantes', val: (left * 365).toLocaleString() },
        { label: 'Fines de semana', val: (left * 52).toLocaleString() },
        { label: 'Tu progreso vital', val: ((age/lifeExp)*100).toFixed(1) + '%' }
      ];

      countersContainer.classList.remove('hidden');
      countersContainer.innerHTML = '';
      phrasesContainer.innerHTML = '';

      data.forEach((d, i) => {
        setTimeout(() => {
          const card = document.createElement('div');
          card.className = 'counter-card';
          card.innerHTML = `<div class="text-orange-500 uppercase tracking-widest text-sm mb-2">${d.label}</div>
                            <div class="text-4xl font-mono font-bold">${d.val}</div>`;
          countersContainer.appendChild(card);
        }, i * 200);
      });

      setTimeout(() => {
        const p = document.createElement('div');
        p.className = 'phrase-box';
        p.textContent = brutalPhrases[Math.floor(Math.random() * brutalPhrases.length)];
        phrasesContainer.appendChild(p);
      }, 1000);
    });
  </script>
</Layout>