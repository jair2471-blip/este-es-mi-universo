---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';

const metadata = {
  title: 'El Manifiesto | El Universo de la Mente',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="El Manifiesto"
    title="Nuestros Principios"
    subtitle="La honestidad brutal es el único camino hacia la verdadera libertad mental."
    image={{ src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?q=80&w=2070', alt: 'Manifiesto' }}
  />

  <section class="px-4 py-16 mx-auto max-w-4xl font-sans text-lg">
    <h2 class="text-3xl font-bold mb-6">La Regla de Oro</h2>
    <p class="mb-4">
      Usted no necesita más información, necesita más ejecución. Deje de hacerse el loco con lo que ya sabe que tiene que hacer.
    </p>
    <ul class="list-disc pl-6 space-y-4">
      <li><strong>Sin Azúcar Añadida:</strong> Aquí no venimos a decirte que todo estará bien.</li>
      <li><strong>Disciplina sobre Motivación:</strong> La motivación es pasajera; la disciplina es eterna.</li>
    </ul>
  </section>
</Layout>
