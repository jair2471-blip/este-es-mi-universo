---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ORÁCULO DE HIERRO | Sentencia de la Calle">
  <div class="min-h-screen bg-[#050505] text-white font-sans flex flex-col items-center justify-center p-4 selection:bg-yellow-600">
    
    <div class="max-w-2xl w-full text-center">
      <div class="mb-12 animate-fade-in">
        <h1 class="text-6xl md:text-7xl font-black tracking-tighter text-yellow-600 uppercase italic leading-none">
          ORÁCULO <br/> DE HIERRO
        </h1>
        <p class="text-zinc-700 tracking-[0.6em] text-[10px] font-bold uppercase mt-4">JUSTICIA FINAL // E.U.L.M</p>
      </div>

      <div class="bg-zinc-950 border-2 border-zinc-900 p-8 shadow-2xl relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-yellow-600 to-transparent opacity-50"></div>

        <textarea
          id="consulta-input"
          class="w-full p-4 bg-black border border-zinc-800 text-white focus:border-yellow-600 outline-none text-2xl mb-6 placeholder:text-zinc-900 text-center uppercase font-black italic tracking-tighter resize-none"
          placeholder="¿QUÉ QUIERE SABER?"
          rows="3"
        ></textarea>

        <button
          id="btn-consultar"
          class="w-full bg-yellow-600 hover:bg-yellow-500 text-black font-black py-5 uppercase italic tracking-[0.2em] transition-all active:scale-95 shadow-[0_0_20px_rgba(202,138,4,0.2)]"
        >
          OBTENER DICTAMEN
        </button>

        <div id="resultado-seccion" class="hidden mt-12 space-y-10 animate-in fade-in slide-in-from-bottom-8 duration-1000">
          
          <div class="py-12 border-y border-zinc-900/50 relative">
             <span class="absolute top-2 left-1/2 -translate-x-1/2 text-[10px] text-yellow-600/40 font-bold tracking-[0.5em] uppercase">Sentencia Directa</span>
            <p id="respuesta-texto" class="text-4xl md:text-5xl font-black uppercase italic leading-none text-white px-2 tracking-tighter"></p>
          </div>

          <div class="space-y-6">
            <button id="btn-compartir-nativa" class="w-full bg-white text-black font-black py-4 text-xs uppercase tracking-[0.3em] hover:bg-yellow-600 transition-all flex items-center justify-center gap-2">
              <span>🔗</span> Compartir en Redes
            </button>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
              {['ig-post', 'ig-story', 'fb', 'tw'].map((fmt) => (
                <button data-format={fmt} class="btn-download bg-zinc-900 p-4 text-[9px] uppercase font-black border border-zinc-800 hover:border-yellow-600 hover:text-yellow-600 transition-all">
                  {fmt.replace('-', ' ')}
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>
      
      <p class="mt-8 text-zinc-800 text-[10px] uppercase font-bold tracking-widest">No apto para gente delicada.</p>
    </div>
  </div>

  <canvas id="hidden-canvas" style="display: none;"></canvas>
</Layout>

<script>
  const btn = document.getElementById('btn-consultar');
  const input = document.getElementById('consulta-input');
  const resContainer = document.getElementById('resultado-seccion');
  const resTexto = document.getElementById('respuesta-texto');

  btn.addEventListener('click', async () => {
    const consulta = input.value.trim();
    if(!consulta) return;
    
    btn.innerText = 'PROCESANDO REALIDAD...';
    btn.disabled = true;

    try {
      const response = await fetch('https://mis-frases.poderparatriunfar.workers.dev/', {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ 
          prompt: `Eres EL ORÁCULO DE HIERRO. Responde a: "${consulta}". Estilo sabio de barrio colombiano, directo, sin filtros, máximo 15 palabras. TODO EN MAYÚSCULAS.` 
        })
      });
      const data = await response.json();
      resTexto.innerText = `"${data.response || data.text || "SISTEMA SIN RESPUESTA."}"`;
      resContainer.classList.remove('hidden');
      resContainer.scrollIntoView({ behavior: 'smooth' });
    } catch (e) {
      resTexto.innerText = "LA VERDAD ES DEMASIADO PESADA HOY.";
      resContainer.classList.remove('hidden');
    } finally {
      btn.innerText = 'OBTENER DICTAMEN';
      btn.disabled = false;
    }
  });

  document.getElementById('btn-compartir-nativa').addEventListener('click', () => {
    const t = `🔮 DICTAMEN DEL ORÁCULO DE HIERRO:\n\n${resTexto.innerText}\n\nConsulta tu destino en: ${window.location.href}`;
    if(navigator.share) navigator.share({text: t});
    else { navigator.clipboard.writeText(t); alert('Copiado al portapapeles.'); }
  });

  document.querySelectorAll('.btn-download').forEach(b => {
    b.addEventListener('click', () => {
      const format = b.getAttribute('data-format');
      const canvas = document.getElementById('hidden-canvas');
      const ctx = canvas.getContext('2d');
      
      const w = 1080;
      let h = 1080;
      if (format === 'ig-story') h = 1920;
      if (format === 'fb' || format === 'tw') h = 600;
      
      canvas.width = w; canvas.height = h;

      // 1. FONDO Y MARCO BERRRACO
      ctx.fillStyle = '#050505'; ctx.fillRect(0, 0, w, h);
      ctx.strokeStyle = '#ca8a04'; ctx.lineWidth = 25;
      ctx.strokeRect(40, 40, w-80, h-80);

      // 2. PREGUNTA (SIGNOS AUTOMÁTICOS)
      let q = input.value.trim().toUpperCase().replace(/^[¿\?]+|[¿\?]+$/g, '');
      ctx.fillStyle = '#222'; ctx.textAlign = 'center';
      ctx.font = '900 30px sans-serif';
      ctx.fillText(`¿${q}?`, w/2, h * 0.12);

      // 3. SENTENCIA CENTRADA
      ctx.fillStyle = '#ffffff';
      ctx.textAlign = 'center';
      ctx.font = 'italic 900 85px sans-serif';
      
      const words = resTexto.innerText.replace(/"/g, '').split(' ');
      let lines = [];
      let currentLine = '';
      
      words.forEach(word => {
        let testLine = currentLine + word + ' ';
        if (ctx.measureText(testLine).width < w * 0.85) {
          currentLine = testLine;
        } else {
          lines.push(currentLine);
          currentLine = word + ' ';
        }
      });
      lines.push(currentLine);

      let startY = (h / 2) - ((lines.length - 1) * 55);
      lines.forEach((l, i) => {
        ctx.fillText(l.trim(), w/2, startY + (i * 110));
      });

      // 4. FIRMA DE MARCA (DIAGRAMACIÓN FINAL)
      ctx.fillStyle = '#ca8a04'; ctx.font = 'black 60px sans-serif';
      ctx.fillText('ORÁCULO DE HIERRO', w/2, h - 180);
      
      ctx.fillStyle = '#222'; ctx.font = 'bold 25px monospace';
      ctx.fillText('SENTENCIA FIRME // E.U.L.M', w/2, h - 110);

      const link = document.createElement('a');
      link.download = `ORACULO-HIERRO-${format}.png`;
      link.href = canvas.toDataURL('image/png');
      link.click();
    });
  });
</script>

<style>
  @keyframes fade-in { from { opacity: 0; } to { opacity: 1; } }
  .animate-fade-in { animation: fade-in 1.5s ease-out; }
</style>