---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ORÁCULO DE HIERRO | Sentencia de la Calle">
  <div class="min-h-screen bg-[#050505] text-white font-sans flex flex-col items-center justify-center p-4 md:p-8 selection:bg-yellow-600">
    
    <div class="max-w-2xl w-full">
      <!-- HEADER MEJORADO -->
      <div class="text-center mb-12 md:mb-20 space-y-3">
        <h1 class="text-6xl md:text-8xl lg:text-9xl font-black tracking-tighter text-yellow-600 uppercase italic leading-[0.85]">
          ORÁCULO<br/><span class="text-white">DE HIERRO</span>
        </h1>
        <div class="h-1 w-24 bg-yellow-600 mx-auto mt-6"></div>
        <p class="text-zinc-600 tracking-[0.6em] text-[10px] md:text-xs font-bold uppercase pt-3">Justicia Final // E.U.L.M</p>
      </div>

      <!-- ZONA DE CONSULTA -->
      <div class="space-y-6 md:space-y-8">
        <div class="relative bg-zinc-950 border border-zinc-900 p-6 md:p-8 rounded-sm">
          <textarea
            id="consulta-input"
            class="w-full bg-transparent text-white outline-none text-xl md:text-2xl placeholder:text-zinc-700 text-center uppercase font-bold tracking-tight transition-all resize-none min-h-[80px]"
            placeholder="SUELTE SU PENA O SU DUDA AQUÍ..."
            rows="2"></textarea>
        </div>

        <button
          id="btn-consultar"
          class="w-full border-2 border-yellow-600 bg-transparent text-yellow-600 hover:bg-yellow-600 hover:text-black font-black py-5 md:py-6 uppercase italic tracking-[0.25em] transition-all duration-300 active:scale-[0.98] text-sm md:text-base"
        >
          PEDIR SENTENCIA
        </button>

        <!-- RESULTADO MEJORADO -->
        <div id="resultado-seccion" class="hidden space-y-8 md:space-y-12 pt-8 md:pt-12">
          
          <!-- SENTENCIA -->
          <div class="bg-zinc-950 border-2 border-yellow-600 p-8 md:p-12 rounded-sm relative overflow-hidden">
            <div class="absolute top-4 left-4 text-5xl md:text-6xl text-zinc-900 font-serif select-none opacity-50">"</div>
            <div class="absolute bottom-4 right-4 text-5xl md:text-6xl text-zinc-900 font-serif select-none opacity-50">"</div>
            
            <p id="respuesta-texto" class="text-3xl md:text-4xl lg:text-5xl font-black uppercase italic leading-[1.15] text-white tracking-tighter text-center py-4 md:py-6 relative z-10"></p>
          </div>

          <!-- ACCIONES MEJORADAS -->
          <div class="space-y-4">
            <!-- Botón compartir principal -->
            <button id="btn-compartir-nativa" class="w-full bg-yellow-600 text-black font-black py-5 text-xs md:text-sm uppercase tracking-[0.3em] hover:bg-yellow-500 transition-all duration-300 active:scale-[0.98]">
              📜 COMPARTIR DICTAMEN
            </button>
            
            <!-- Opciones de descarga -->
            <div class="pt-4 border-t border-zinc-900">
              <p class="text-zinc-600 text-[10px] uppercase tracking-widest text-center mb-3 font-bold">Descargar imagen para:</p>
              <div class="grid grid-cols-4 gap-2 md:gap-3">
                <button data-format="post" class="btn-download bg-zinc-950 border border-zinc-800 p-4 md:p-5 text-[9px] md:text-[10px] uppercase font-bold text-zinc-400 hover:border-yellow-600 hover:text-yellow-600 hover:bg-zinc-900 transition-all duration-300">
                  <span class="block mb-1">📱</span>
                  POST
                </button>
                <button data-format="story" class="btn-download bg-zinc-950 border border-zinc-800 p-4 md:p-5 text-[9px] md:text-[10px] uppercase font-bold text-zinc-400 hover:border-yellow-600 hover:text-yellow-600 hover:bg-zinc-900 transition-all duration-300">
                  <span class="block mb-1">📲</span>
                  STORY
                </button>
                <button data-format="fb" class="btn-download bg-zinc-950 border border-zinc-800 p-4 md:p-5 text-[9px] md:text-[10px] uppercase font-bold text-zinc-400 hover:border-yellow-600 hover:text-yellow-600 hover:bg-zinc-900 transition-all duration-300">
                  <span class="block mb-1">👥</span>
                  FB
                </button>
                <button data-format="tw" class="btn-download bg-zinc-950 border border-zinc-800 p-4 md:p-5 text-[9px] md:text-[10px] uppercase font-bold text-zinc-400 hover:border-yellow-600 hover:text-yellow-600 hover:bg-zinc-900 transition-all duration-300">
                  <span class="block mb-1">🐦</span>
                  TW
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- FOOTER SUTIL -->
      <div class="text-center mt-16 md:mt-20 opacity-30 hover:opacity-60 transition-opacity">
        <p class="text-zinc-700 text-[9px] tracking-widest uppercase">La sentencia es inapelable</p>
      </div>
    </div>
  </div>

  <canvas id="hidden-canvas" style="display: none;"></canvas>
</Layout>

<style>
  @keyframes fadeSlideIn {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-in { animation: fadeSlideIn 0.8s cubic-bezier(0.16, 1, 0.3, 1); }
</style>

<script>
  const btn = document.getElementById('btn-consultar') as HTMLButtonElement;
  const input = document.getElementById('consulta-input') as HTMLTextAreaElement;
  const resContainer = document.getElementById('resultado-seccion') as HTMLDivElement;
  const resTexto = document.getElementById('respuesta-texto') as HTMLParagraphElement;

  btn.addEventListener('click', async () => {
    const consulta = input.value.trim();
    if(!consulta) return;
    
    btn.innerText = 'DICTANDO...';
    btn.disabled = true;

    try {
  const response = await fetch('https://mis-frases.poderparatriunfar.workers.dev/', {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
  prompt: `ERES EL ORÁCULO DE LA MENTE.

EL USUARIO TE DICE: "${consulta}"

INSTRUCCIONES:
1. RESPONDE CON CLARIDAD, FIRMEZA Y SOBRIEDAD.
2. NO USES METÁFORAS, POESÍA NI ADORNOS.
3. NO JUZGUES, NO HUMILLES, NO RIDICULICES.
4. DECLARA UNA SOLA VERDAD DIRECTA.

ESTILO:
- MÁXIMO 12 PALABRAS.
- FRASE ÚNICA.
- LENGUAJE PRECISO Y CONTUNDENTE.
- TODO EN MAYÚSCULAS.
- SIN GROCERÍAS, SIN SARCASMO, SIN MOTIVACIÓN VACÍA.`
   })
  });

  const data = await response.json();
  resTexto.innerText =
    data.response || data.text || data.message || "EL ORÁCULO GUARDA SILENCIO.";

  resContainer.classList.remove('hidden');
  resContainer.classList.add('animate-in');

  setTimeout(() => {
    resContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }, 100);

} catch (e) {
  resTexto.innerText = "ERROR EN LA MATRIZ.";
  resContainer.classList.remove('hidden');

} finally {
  btn.innerText = 'PEDIR SENTENCIA';
  btn.disabled = false;
}

  });

  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      btn.click();
    }
  });

  document.querySelectorAll('.btn-download').forEach(b => {
    b.addEventListener('click', () => {
      const format = b.getAttribute('data-format');
      const canvas = document.getElementById('hidden-canvas') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      const dimensions = {
        post: { w: 1080, h: 1080 },
        story: { w: 1080, h: 1920 },
        fb: { w: 1200, h: 630 },
        tw: { w: 1200, h: 675 }
      };

      const { w, h } = dimensions[format] || dimensions.post;
      canvas.width = w;
      canvas.height = h;

      ctx.fillStyle = '#050505';
      ctx.fillRect(0, 0, w, h);
      
      ctx.strokeStyle = '#1a1a1a';
      ctx.lineWidth = 30;
      ctx.strokeRect(15, 15, w-30, h-30);

      // LÓGICA INTELIGENTE DE ENCABEZADO - MEJORADO
      let textoUsuario = input.value.trim().toUpperCase();
      let encabezadoFinal = textoUsuario;
      const palabrasPregunta = ['QUÉ', 'CÓMO', 'CUÁNDO', 'QUIÉN', 'DÓNDE', 'POR QUÉ', 'SERÁ'];
      const esPregunta = palabrasPregunta.some(p => textoUsuario.includes(p)) || textoUsuario.includes('?');

      if (esPregunta) {
        let limpia = textoUsuario.replace(/^[¿\?]+|[¿\?]+$/g, '');
        encabezadoFinal = `¿${limpia}?`;
      }

      // Pregunta con color más visible y mejor tamaño
      ctx.fillStyle = '#666666'; 
      ctx.textAlign = 'center';
      const preguntaSize = Math.floor(w * 0.028);
      ctx.font = `bold ${preguntaSize}px Arial, sans-serif`;
      ctx.fillText(encabezadoFinal.substring(0, 60), w/2, h * 0.12);

      // SENTENCIA - MÁS ESPACIOSA
      ctx.fillStyle = '#ffffff';
      const fontSize = format === 'story' ? Math.floor(w * 0.07) : Math.floor(w * 0.065);
      ctx.font = `italic 900 ${fontSize}px Arial, sans-serif`;
      
      const words = resTexto.innerText.split(' ');
      const maxWidth = w * 0.80; // Reducido para más margen
      let lines = [], currentLine = '';

      words.forEach(word => {
        if (ctx.measureText(currentLine + word).width < maxWidth) {
          currentLine += word + ' ';
        } else {
          lines.push(currentLine.trim());
          currentLine = word + ' ';
        }
      });
      lines.push(currentLine.trim());

      const lineHeight = fontSize * 1.4; // Más espacio entre líneas
      let startY = (h / 2) - ((lines.length - 1) * lineHeight / 2);

      lines.forEach(line => {
        ctx.fillText(line, w/2, startY);
        startY += lineHeight;
      });

      // FIRMA
      const footerY = h - (h * 0.1);
      ctx.fillStyle = '#ca8a04';
      ctx.fillRect(w/2 - 40, footerY - 60, 80, 4);
      ctx.font = `900 ${Math.floor(w * 0.045)}px Arial, sans-serif`;
      ctx.fillText('ORÁCULO DE HIERRO', w/2, footerY);
      
      ctx.fillStyle = '#333';
      ctx.font = `bold ${Math.floor(w * 0.02)}px monospace`;
      ctx.fillText('SENTENCIA FIRME // E.U.L.M', w/2, footerY + 40);

      const link = document.createElement('a');
      link.download = `ORACULO-${format}.png`;
      link.href = canvas.toDataURL('image/png');
      link.click();
    });
  });

  document.getElementById('btn-compartir-nativa')?.addEventListener('click', async () => {
    const texto = `📜 SENTENCIA DEL ORÁCULO DE HIERRO:\n\n"${resTexto.innerText}"\n\nConsulta el tuyo: ${window.location.href}`;
    if (navigator.share) {
      try { await navigator.share({ text: texto }); } catch (e) {}
    } else {
      await navigator.clipboard.writeText(texto);
      alert('Copiado al portapapeles');
    }
  });
</script>