---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ORÁCULO DE HIERRO | Sentencia de la Calle">
  <div class="min-h-screen bg-[#050505] text-white font-sans flex flex-col items-center justify-center p-6 selection:bg-yellow-600">
    
    <div class="max-w-xl w-full">
      <div class="text-center mb-16 space-y-2">
        <h1 class="text-7xl md:text-8xl font-black tracking-tighter text-yellow-600 uppercase italic leading-[0.8]">
          ORÁCULO<br/><span class="text-white">DE HIERRO</span>
        </h1>
        <div class="h-1 w-20 bg-yellow-600 mx-auto mt-4"></div>
        <p class="text-zinc-600 tracking-[0.8em] text-[9px] font-bold uppercase pt-2">Justicia Final // E.U.L.M</p>
      </div>

      <div class="space-y-8">
        <div class="relative">
          <textarea
  id="consulta-input"
  class="..."
  placeholder="SUELTE SU PENA O SU DUDA AQUÍ..."
></textarea>
        </div>

        <button
          id="btn-consultar"
          class="w-full border-2 border-yellow-600 text-yellow-600 hover:bg-yellow-600 hover:text-black font-black py-4 uppercase italic tracking-[0.3em] transition-all active:scale-95"
        >
          PEDIR SENTENCIA
        </button>

        <div id="resultado-seccion" class="hidden space-y-12 pt-10">
          
          <div class="text-center relative py-10">
            <span class="absolute top-0 left-0 text-6xl text-zinc-900 font-serif select-none">"</span>
            <p id="respuesta-texto" class="text-4xl md:text-5xl font-black uppercase italic leading-[1.1] text-white tracking-tighter px-8"></p>
            <span class="absolute bottom-0 right-0 text-6xl text-zinc-900 font-serif select-none">"</span>
          </div>

          <div class="grid grid-cols-1 gap-4">
            <button id="btn-compartir-nativa" class="w-full bg-zinc-100 text-black font-black py-4 text-[10px] uppercase tracking-[0.4em] hover:bg-yellow-600 transition-all">
              COMPARTIR DICTAMEN
            </button>
            
            <div class="grid grid-cols-4 gap-2">
              <button data-format="post" class="btn-download bg-transparent border border-zinc-900 p-3 text-[8px] uppercase font-bold text-zinc-500 hover:border-yellow-600 hover:text-yellow-600 transition-all">
                POST
              </button>
              <button data-format="story" class="btn-download bg-transparent border border-zinc-900 p-3 text-[8px] uppercase font-bold text-zinc-500 hover:border-yellow-600 hover:text-yellow-600 transition-all">
                STORY
              </button>
              <button data-format="fb" class="btn-download bg-transparent border border-zinc-900 p-3 text-[8px] uppercase font-bold text-zinc-500 hover:border-yellow-600 hover:text-yellow-600 transition-all">
                FB
              </button>
              <button data-format="tw" class="btn-download bg-transparent border border-zinc-900 p-3 text-[8px] uppercase font-bold text-zinc-500 hover:border-yellow-600 hover:text-yellow-600 transition-all">
                TW
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <canvas id="hidden-canvas" style="display: none;"></canvas>
</Layout>

<style>
  @keyframes fadeSlideIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-in {
    animation: fadeSlideIn 1s ease-out;
  }
</style>

<script>
  const btn = document.getElementById('btn-consultar') as HTMLButtonElement;
  const input = document.getElementById('consulta-input') as HTMLTextAreaElement;
  const resContainer = document.getElementById('resultado-seccion') as HTMLDivElement;
  const resTexto = document.getElementById('respuesta-texto') as HTMLParagraphElement;

  btn.addEventListener('click', async () => {
    const consulta = input.value.trim();
    if(!consulta) return;
    
    btn.innerText = 'DICTANDO...';
    btn.disabled = true;

    try {
      const response = await fetch('https://mis-frases.poderparatriunfar.workers.dev/', {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ 
          prompt: `Eres EL ORÁCULO DE HIERRO. El usuario te dice: "${consulta}". 
Reacciona, aconseja o sentencia con sabiduría callejera colombiana. 
Sé directo, crudo y sin filtros. Máximo 15 palabras. TODO EN MAYÚSCULAS.` 
        })
      });
      
      const data = await response.json();
      resTexto.innerText = data.response || data.text || data.message || "EL HIERRO NO HABLA HOY.";
      
      resContainer.classList.remove('hidden');
      resContainer.classList.add('animate-in');
      
      // Scroll suave
      setTimeout(() => {
        resContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }, 100);
      
    } catch (e) {
      console.error('Error:', e);
      resTexto.innerText = "ERROR EN LA MATRIZ.";
      resContainer.classList.remove('hidden');
      resContainer.classList.add('animate-in');
    } finally {
      btn.innerText = 'PEDIR SENTENCIA';
      btn.disabled = false;
    }
  });

  // Enter para enviar
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      btn.click();
    }
  });

  // GENERACIÓN DE IMÁGENES
  document.querySelectorAll('.btn-download').forEach(b => {
    b.addEventListener('click', () => {
      const format = b.getAttribute('data-format');
      const canvas = document.getElementById('hidden-canvas') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      // Dimensiones según formato
      const dimensions = {
        post: { w: 1080, h: 1080 },
        story: { w: 1080, h: 1920 },
        fb: { w: 1200, h: 630 },
        tw: { w: 1200, h: 675 }
      };

      const { w, h } = dimensions[format] || dimensions.post;
      canvas.width = w;
      canvas.height = h;

      // FONDO NEGRO PREMIUM
      ctx.fillStyle = '#050505';
      ctx.fillRect(0, 0, w, h);
      
      // MARCO SUTIL
      ctx.strokeStyle = '#1a1a1a';
      ctx.lineWidth = 30;
      ctx.strokeRect(15, 15, w-30, h-30);

      // LÓGICA INTELIGENTE DE ENCABEZADO
let textoUsuario = input.value.trim().toUpperCase();
let encabezadoFinal = textoUsuario;

// Si parece pregunta (tiene palabras clave o el usuario puso un signo), le ponemos signos
const palabrasPregunta = ['QUÉ', 'CÓMO', 'CUÁNDO', 'QUIÉN', 'DÓNDE', 'POR QUÉ', 'SERÁ'];
const esPregunta = palabrasPregunta.some(p => textoUsuario.includes(p)) || textoUsuario.includes('?');

if (esPregunta) {
  let limpia = textoUsuario.replace(/^[¿\?]+|[¿\?]+$/g, '');
  encabezadoFinal = `¿${limpia}?`;
}

ctx.fillStyle = '#222'; ctx.textAlign = 'center';
ctx.font = 'bold 26px monospace';
ctx.fillText(encabezadoFinal.substring(0, 60), w/2, h * 0.12);

      // 2. SENTENCIA (centro, protagonista)
      ctx.fillStyle = '#ffffff';
      const fontSize = format === 'story' ? Math.floor(w * 0.07) : Math.floor(w * 0.075);
      ctx.font = `italic 900 ${fontSize}px Arial, sans-serif`;
      
      const respuestaTexto = resTexto.innerText;
      const words = respuestaTexto.split(' ');
      const maxWidth = w * 0.85;
      let lines = [];
      let currentLine = '';

      words.forEach(word => {
        const testLine = currentLine + word + ' ';
        const metrics = ctx.measureText(testLine);
        if (metrics.width > maxWidth && currentLine !== '') {
          lines.push(currentLine.trim());
          currentLine = word + ' ';
        } else {
          currentLine = testLine;
        }
      });
      if (currentLine) lines.push(currentLine.trim());

      const lineHeight = fontSize * 1.3;
      const totalHeight = lines.length * lineHeight;
      let startY = (h / 2) - (totalHeight / 2) + (fontSize * 0.7);

      lines.forEach(line => {
        ctx.fillText(line, w/2, startY);
        startY += lineHeight;
      });

      // 3. FIRMA ESTÉTICA (abajo)
      const footerY = h - (h * 0.12);
      
      // Línea decorativa arriba del footer
      ctx.fillStyle = '#ca8a04';
      ctx.fillRect(w/2 - (w * 0.04), footerY - (h * 0.08), w * 0.08, 3);

      // Título
      ctx.font = `900 ${Math.floor(w * 0.04)}px Arial, sans-serif`;
      ctx.fillText('ORÁCULO DE HIERRO', w/2, footerY);
      
      // Subtítulo
      ctx.fillStyle = '#333333';
      ctx.font = `bold ${Math.floor(w * 0.018)}px monospace`;
      ctx.fillText('SENTENCIA FIRME // E.U.L.M', w/2, footerY + (h * 0.045));

      // Descargar imagen
      const link = document.createElement('a');
      link.download = `ORACULO-${format}-${Date.now()}.png`;
      link.href = canvas.toDataURL('image/png');
      link.click();
    });
  });

  // Compartir nativo
  document.getElementById('btn-compartir-nativa')?.addEventListener('click', async () => {
    const texto = `📜 SENTENCIA DEL ORÁCULO DE HIERRO:\n\n"${resTexto.innerText}"\n\nConsulta el tuyo: ${window.location.href}`;
    
    if (navigator.share) {
      try {
        await navigator.share({ text: texto });
      } catch (e) {
        console.log('Share cancelled');
      }
    } else {
      // Fallback: copiar al portapapeles
      await navigator.clipboard.writeText(texto);
      alert('Texto copiado al portapapeles');
    }
  });
</script>