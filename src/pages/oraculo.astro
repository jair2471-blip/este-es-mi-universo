---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ORÁCULO DE HIERRO | Sentencia de la Calle">
  <div class="min-h-screen bg-[#050505] text-white font-sans flex flex-col items-center justify-center p-6 selection:bg-yellow-600">
    
    <div class="max-w-xl w-full">
      <div class="text-center mb-16 space-y-2">
        <h1 class="text-7xl md:text-8xl font-black tracking-tighter text-yellow-600 uppercase italic leading-[0.8]">
          ORÁCULO<br/><span class="text-white">DE HIERRO</span>
        </h1>
        <div class="h-1 w-20 bg-yellow-600 mx-auto mt-4"></div>
        <p class="text-zinc-600 tracking-[0.8em] text-[9px] font-bold uppercase pt-2">Justicia Final // E.U.L.M</p>
      </div>

      <div class="space-y-8">
        <div class="relative">
          <textarea
            id="consulta-input"
            class="w-full bg-transparent border-b-2 border-zinc-900 text-white focus:border-yellow-600 outline-none text-2xl py-4 placeholder:text-zinc-800 text-center uppercase font-bold tracking-tighter transition-all resize-none"
            placeholder="Escriba su duda..."
            rows="2"
          ></textarea>
        </div>

        <button
          id="btn-consultar"
          class="w-full border-2 border-yellow-600 text-yellow-600 hover:bg-yellow-600 hover:text-black font-black py-4 uppercase italic tracking-[0.3em] transition-all active:scale-95"
        >
          PEDIR SENTENCIA
        </button>

        <div id="resultado-seccion" class="hidden space-y-12 pt-10 animate-in fade-in slide-in-from-bottom-10 duration-1000">
          
          <div class="text-center relative py-10">
            <span class="absolute top-0 left-0 text-6xl text-zinc-900 font-serif">“</span>
            <p id="respuesta-texto" class="text-4xl md:text-5xl font-black uppercase italic leading-[1.1] text-white tracking-tighter"></p>
            <span class="absolute bottom-0 right-0 text-6xl text-zinc-900 font-serif">”</span>
          </div>

          <div class="grid grid-cols-1 gap-4">
            <button id="btn-compartir-nativa" class="w-full bg-zinc-100 text-black font-black py-4 text-[10px] uppercase tracking-[0.4em] hover:bg-yellow-600 transition-all">
              COMPARTIR DICTAMEN
            </button>
            
            <div class="grid grid-cols-4 gap-2">
              {['post', 'story', 'fb', 'tw'].map((fmt) => (
                <button data-format={fmt} class="btn-download bg-transparent border border-zinc-900 p-3 text-[8px] uppercase font-bold text-zinc-500 hover:border-yellow-600 hover:text-yellow-600 transition-all">
                  {fmt}
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <canvas id="hidden-canvas" style="display: none;"></canvas>
</Layout>

<script>
  const btn = document.getElementById('btn-consultar');
  const input = document.getElementById('consulta-input');
  const resContainer = document.getElementById('resultado-seccion');
  const resTexto = document.getElementById('respuesta-texto');

  btn.addEventListener('click', async () => {
    const consulta = input.value.trim();
    if(!consulta) return;
    btn.innerText = 'DICTANDO...';
    btn.disabled = true;

    try {
      const response = await fetch('https://mis-frases.poderparatriunfar.workers.dev/', {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ prompt: `Eres EL ORÁCULO DE HIERRO. Responde a: "${consulta}". Estilo sabio de barrio colombiano, directo, berraco, máximo 12 palabras. TODO EN MAYÚSCULAS.` })
      });
      const data = await response.json();
      resTexto.innerText = data.response || data.text || "EL HIERRO NO HABLA HOY.";
      resContainer.classList.remove('hidden');
      resContainer.scrollIntoView({ behavior: 'smooth' });
    } catch (e) {
      resTexto.innerText = "ERROR EN LA MATRIZ.";
    } finally {
      btn.innerText = 'PEDIR SENTENCIA';
      btn.disabled = false;
    }
  });

  // LÓGICA DE DIAGRAMACIÓN EN CANVAS
  document.querySelectorAll('.btn-download').forEach(b => {
    b.addEventListener('click', () => {
      const format = b.getAttribute('data-format');
      const canvas = document.getElementById('hidden-canvas');
      const ctx = canvas.getContext('2d');
      const w = 1080, h = (format === 'story' ? 1920 : (format === 'fb' || format === 'tw' ? 600 : 1080));
      canvas.width = w; canvas.height = h;

      // FONDO NEGRO PREMIUM
      ctx.fillStyle = '#050505'; ctx.fillRect(0, 0, w, h);
      
      // MARCO SUTIL
      ctx.strokeStyle = '#111'; ctx.lineWidth = 40;
      ctx.strokeRect(20, 20, w-40, h-40);

      // 1. PREGUNTA (SIGNOS AUTO)
      let q = input.value.trim().toUpperCase().replace(/^[¿\?]+|[¿\?]+$/g, '');
      ctx.fillStyle = '#222'; ctx.textAlign = 'center';
      ctx.font = 'bold 25px monospace';
      ctx.fillText(`¿${q}?`, w/2, h * 0.15);

      // 2. SENTENCIA (DIAGRAMACIÓN CENTRAL)
      ctx.fillStyle = '#ffffff';
      ctx.font = 'italic 900 85px sans-serif';
      const words = resTexto.innerText.split(' ');
      let lines = [], line = '';
      words.forEach(word => {
        if (ctx.measureText(line + word).width < w * 0.8) line += word + ' ';
        else { lines.push(line); line = word + ' '; }
      });
      lines.push(line);

      let y = (h/2) - ((lines.length - 1) * 50);
      lines.forEach(l => {
        ctx.fillText(l.trim(), w/2, y);
        y += 110;
      });

      // 3. FIRMA ESTÉTICA (COMO UN SELLO)
      const footerY = h - 150;
      ctx.fillStyle = '#ca8a04'; ctx.font = '900 50px sans-serif';
      ctx.fillText('ORÁCULO DE HIERRO', w/2, footerY);
      
      ctx.fillStyle = '#222'; ctx.font = 'bold 20px monospace';
      ctx.fillText('SENTENCIA FIRME // E.U.L.M', w/2, footerY + 60);
      
      // Línea decorativa final
      ctx.fillStyle = '#ca8a04'; ctx.fillRect(w/2 - 40, footerY - 80, 80, 4);

      const link = document.createElement('a');
      link.download = `ORACULO-${format}.png`;
      link.href = canvas.toDataURL('image/png');
      link.click();
    });
  });

  document.getElementById('btn-compartir-nativa').addEventListener('click', () => {
    const t = `📜 SENTENCIA DEL ORÁCULO DE HIERRO:\n\n"${resTexto.innerText}"\n\nConsulta el tuyo: ${window.location.href}`;
    navigator.share ? navigator.share({text: t}) : alert('Copiado');
  });
</script>