---
// src/pages/oraculo.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="ORACULO.ASTRO | Sabiduría de Barrio">
  <div id="oraculo-root" class="min-h-screen bg-[#050505] text-white font-sans flex flex-col items-center justify-center p-6 selection:bg-indigo-500">
    
    <div class="text-center mb-10 group">
      <div class="flex items-center justify-center gap-2 mb-2">
        <span class="text-4xl">🚀</span>
        <h1 class="text-5xl md:text-6xl font-black tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500">
          ORACULO.ASTRO
        </h1>
      </div>
      <p class="text-zinc-500 tracking-[0.3em] text-[10px] font-bold uppercase">
        La verdad del cosmos, traída al barrio
      </p>
    </div>

    <div class="max-w-xl w-full bg-zinc-900/50 border border-zinc-800 p-8 rounded-3xl backdrop-blur-xl shadow-2xl">
      <div class="mb-6">
        <label class="text-indigo-400 text-[10px] font-bold uppercase tracking-widest mb-3 block">
          ▸ Escupe tu duda mortal:
        </label>
        <textarea
          id="consulta-input"
          class="w-full bg-black/50 border-2 border-zinc-800 rounded-2xl p-4 text-xl focus:border-indigo-500 outline-none transition-all placeholder:text-zinc-700 resize-none text-white"
          placeholder="¿Ese negocio me conviene?"
          rows="3"
        ></textarea>
      </div>

      <button
        id="btn-invocar"
        class="w-full bg-indigo-600 hover:bg-indigo-500 disabled:bg-zinc-800 py-5 rounded-2xl font-black text-lg transition-all active:scale-95 shadow-lg shadow-indigo-500/20 uppercase tracking-widest"
      >
        INVOCAR SENTENCIA
      </button>

      <div id="respuesta-container" class="hidden mt-8 space-y-6 animate-fade-in">
        <div class="p-6 bg-gradient-to-br from-indigo-900/30 to-purple-900/30 border border-indigo-500/50 rounded-2xl">
          <span class="text-4xl mb-4 block">🔮</span>
          <p id="respuesta-texto" class="text-2xl md:text-3xl font-black leading-tight tracking-tight uppercase italic text-indigo-50">
            </p>
        </div>
      </div>
    </div>

    <footer class="mt-12 text-zinc-600 text-[10px] font-bold uppercase tracking-widest">
      © 2026 ORACULO.ASTRO // La calle no miente, parce.
    </footer>
  </div>
</Layout>

<script>
  // LÓGICA DEL ORÁCULO
  const btnInvocar = document.getElementById('btn-invocar');
  const inputConsulta = document.getElementById('consulta-input');
  const containerRespuesta = document.getElementById('respuesta-container');
  const textoRespuesta = document.getElementById('respuesta-texto');

  btnInvocar.addEventListener('click', async () => {
    const consulta = inputConsulta.value.trim();
    if (!consulta) return;

    // Estado Cargando
    btnInvocar.disabled = true;
    btnInvocar.innerText = 'SINTONIZANDO EL VACÍO...';
    containerRespuesta.classList.add('hidden');

    try {
      const response = await fetch('https://mis-frases.poderparatriunfar.workers.dev/', {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          prompt: `Eres ORACULO.ASTRO. Responde a: "${consulta}". Usa jerga colombiana (parce, mijo, etc), sé directo y crudo, máximo 15 palabras, formato causa-efecto. EN MAYÚSCULAS.`
        })
      });

      const data = await response.json();
      const finalResult = data.response || data.text || data.message || "EL DESTINO ESTÁ NUBLADO.";

      // Mostrar Respuesta
      textoRespuesta.innerText = `"${finalResult.toUpperCase()}"`;
      containerRespuesta.classList.remove('hidden');
      
    } catch (error) {
      console.error(error);
      textoRespuesta.innerText = "INTERFERENCIA ASTRAL. INTENTA LUEGO.";
      containerRespuesta.classList.remove('hidden');
    } finally {
      btnInvocar.disabled = false;
      btnInvocar.innerText = 'INVOCAR SENTENCIA';
    }
  });
</script>

<style>
  /* Animación simple para que la respuesta no aparezca de golpe */
  .animate-fade-in {
    animation: fadeIn 0.5s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Quitar el outline azul feo en móviles */
  textarea:focus {
    box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
  }
</style>