---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ORACULO.ASTRO | La Verdad sin Anestesia">
  <div class="min-h-screen bg-[#050505] text-white font-sans flex flex-col items-center justify-center p-4 selection:bg-indigo-500">
    
    <div class="max-w-2xl w-full">
      <div class="text-center mb-8">
        <div class="flex items-center justify-center gap-3 mb-4">
          <span class="text-4xl animate-pulse">✨</span>
          <h1 class="text-5xl font-black tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-yellow-400 via-orange-500 to-red-600">
            ORACULO.ASTRO
          </h1>
          <span class="text-4xl animate-pulse">✨</span>
        </div>
        <p class="text-yellow-200/80 text-lg italic">"La verdad sin anestesia, parce"</p>
      </div>

      <div class="bg-zinc-900/40 backdrop-blur-md rounded-3xl p-6 shadow-2xl border-2 border-yellow-600/30">
        <div class="mb-6">
          <label class="block text-yellow-400 font-bold mb-2 text-lg uppercase tracking-widest">
            ◢ ¿Qué te inquieta, mijo?
          </label>
          <textarea
            id="consulta-input"
            class="w-full p-4 bg-black/60 text-white border-2 border-yellow-600/50 rounded-2xl focus:outline-none focus:border-yellow-400 placeholder-gray-600 min-h-[100px] resize-none text-xl"
            placeholder="Ej: ¿Ese socio me va a tumbar?..."
          ></textarea>
        </div>

        <button
          id="btn-consultar"
          class="w-full bg-gradient-to-r from-yellow-600 to-orange-700 hover:from-yellow-500 hover:to-orange-600 text-white font-black py-4 px-6 rounded-2xl transition-all transform active:scale-95 shadow-lg text-xl uppercase tracking-tighter"
        >
          CONSULTAR AL ORÁCULO
        </button>

        <div id="resultado-seccion" class="hidden space-y-6 mt-6 animate-in slide-in-from-bottom-10 duration-500">
          
          <div class="p-6 bg-yellow-400/5 border-2 border-yellow-400/40 rounded-2xl">
            <div class="flex items-start gap-4">
              <span class="text-4xl">🔮</span>
              <div>
                <h3 class="text-yellow-400 font-bold mb-2 uppercase text-xs tracking-[0.3em]">El oráculo sentencia:</h3>
                <p id="respuesta-texto" class="text-white text-2xl md:text-3xl leading-tight font-black uppercase italic">
                  </p>
              </div>
            </div>
          </div>

          <div class="p-6 bg-black/40 border-2 border-zinc-800 rounded-2xl space-y-6">
            <div class="text-center">
              <h3 class="text-yellow-400 font-bold mb-4 flex items-center justify-center gap-2 uppercase text-xs tracking-widest">
                <span>🔗</span> Compartir
              </h3>
              <button id="btn-compartir-nativa" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white font-bold py-4 rounded-xl transition-all flex items-center justify-center gap-2 shadow-lg">
                COMPARTIR EN REDES
              </button>
            </div>

            <div class="text-center">
              <h3 class="text-yellow-400 font-bold mb-4 flex items-center justify-center gap-2 uppercase text-xs tracking-widest">
                <span>⬇️</span> Descargar imágenes
              </h3>
              <div class="grid grid-cols-2 gap-3">
                <button data-format="ig-post" class="btn-download bg-gradient-to-r from-purple-600 to-pink-600 p-3 rounded-xl font-bold text-xs uppercase transition-all hover:opacity-80">IG Post</button>
                <button data-format="ig-story" class="btn-download bg-gradient-to-r from-purple-600 to-pink-600 p-3 rounded-xl font-bold text-xs uppercase transition-all hover:opacity-80">IG Story</button>
                <button data-format="fb" class="btn-download bg-blue-700 p-3 rounded-xl font-bold text-xs uppercase transition-all hover:opacity-80">Facebook</button>
                <button data-format="tw" class="btn-download bg-sky-600 p-3 rounded-xl font-bold text-xs uppercase transition-all hover:opacity-80">Twitter/X</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <canvas id="hidden-canvas" style="display: none;"></canvas>
</Layout>

<script>
  const btnConsultar = document.getElementById('btn-consultar');
  const input = document.getElementById('consulta-input');
  const seccionResultado = document.getElementById('resultado-seccion');
  const textoRespuesta = document.getElementById('respuesta-texto');

  // LÓGICA DE CONSULTA
  btnConsultar.addEventListener('click', async () => {
    const consulta = input.value.trim();
    if (!consulta) return;

    btnConsultar.disabled = true;
    btnConsultar.innerText = 'SINTONIZANDO EL COSMOS...';

    try {
      const response = await fetch('https://mis-frases.poderparatriunfar.workers.dev/', {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          prompt: `Eres ORACULO.ASTRO. Responde a: "${consulta}". Jerga colombiana de calle, directo, máximo 15 palabras, causa-efecto. MAYÚSCULAS.`
        })
      });

      const data = await response.json();
      const res = data.response || data.text || data.message || "EL COSMOS NO RESPONDE.";
      
      textoRespuesta.innerText = `"${res.toUpperCase()}"`;
      seccionResultado.classList.remove('hidden');
      seccionResultado.scrollIntoView({ behavior: 'smooth' });

    } catch (e) {
      textoRespuesta.innerText = "HUBO UN CORTO EN EL BARRIO. INTENTA LUEGO.";
      seccionResultado.classList.remove('hidden');
    } finally {
      btnConsultar.disabled = false;
      btnConsultar.innerText = 'CONSULTAR AL ORÁCULO';
    }
  });

  // COMPARTIR NATIVO
  document.getElementById('btn-compartir-nativa').addEventListener('click', async () => {
    const texto = `🔮 ORACULO.ASTRO SENTENCIA:\n\n${textoRespuesta.innerText}\n\n"La verdad sin anestesia, parce"`;
    if (navigator.share) {
      await navigator.share({ title: 'Oráculo Astro', text: texto });
    } else {
      navigator.clipboard.writeText(texto);
      alert('¡Copiado al portapapeles, parce!');
    }
  });

  // GENERAR IMAGEN PARA DESCARGAR
  document.querySelectorAll('.btn-download').forEach(btn => {
    btn.addEventListener('click', () => {
      const format = btn.getAttribute('data-format');
      const canvas = document.getElementById('hidden-canvas');
      const ctx = canvas.getContext('2d');
      
      let w = 1080, h = 1080;
      if (format === 'ig-story') h = 1920;
      if (format === 'fb' || format === 'tw') h = 630;

      canvas.width = w; canvas.height = h;

      // FONDO
      const grad = ctx.createLinearGradient(0, 0, 0, h);
      grad.addColorStop(0, '#1a1a1a'); grad.addColorStop(1, '#450a0a');
      ctx.fillStyle = grad; ctx.fillRect(0, 0, w, h);

      // MARCO
      ctx.strokeStyle = '#facc15'; ctx.lineWidth = 20;
      ctx.strokeRect(40, 40, w-80, h-80);

      // TEXTO
      ctx.fillStyle = '#ffffff'; ctx.textAlign = 'center';
      ctx.font = `bold ${w * 0.08}px Arial`;
      ctx.fillText('ORACULO.ASTRO', w/2, h * 0.15);
      
      ctx.font = `bold ${w * 0.05}px Arial`;
      const words = textoRespuesta.innerText.split(' ');
      let line = '', y = h/2 - 50;
      words.forEach(word => {
        if (ctx.measureText(line + word).width < w * 0.8) line += word + ' ';
        else { ctx.fillText(line, w/2, y); line = word + ' '; y += 70; }
      });
      ctx.fillText(line, w/2, y);

      // DESCARGA
      const link = document.createElement('a');
      link.download = `sentencia-${format}.png`;
      link.href = canvas.toDataURL();
      link.click();
    });
  });
</script>